---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_CONFIG } from '../utils/meta';
---
<SiteLayout title={`404 — ${SITE_CONFIG.name}`} description="Página no encontrada." robots="noindex, nofollow">
  <main class="h-404-wrap">
    <div class="h-404-code" aria-hidden="true">404</div>
    <div class="h-404-inner">
      <span class="h-404-eyebrow">Error 404</span>
      <h1 class="h-404-h1">Página no<br/><span class="h-grad">encontrada.</span></h1>
      <p class="h-404-lead">La URL que buscás no existe o fue movida. Revisá que esté bien escrita o volvé al inicio.</p>
      <div class="h-404-actions">
        <a href="/" class="h-btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Ir al inicio
        </a>
        <a href="/#precios" class="h-btn-ghost">Ver precios</a>
      </div>
      <div class="h-404-links">
        <span>O ir directo a:</span>
        <a href="/#producto">Producto</a>
        <a href="/#faq">FAQ</a>
        <a href="/privacidad">Privacidad</a>
        <a href="/terminos">Términos</a>
      </div>
    </div>
  </main>
</SiteLayout>

<style is:global>
.h-404-wrap {
  position: relative; z-index: 1;
  min-height: calc(100vh - 80px);
  display: flex; align-items: center; justify-content: center;
  padding: clamp(48px,8vw,96px) clamp(20px,4vw,48px);
  overflow: hidden;
}
.h-404-code {
  position: absolute; z-index: 0;
  font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700;
  font-size: clamp(160px, 28vw, 400px); line-height: 1;
  letter-spacing: -.06em; color: transparent;
  -webkit-text-stroke: 1px var(--line-2);
  user-select: none; pointer-events: none;
  top: 50%; left: 50%; transform: translate(-50%, -50%);
  white-space: nowrap;
}
.h-404-inner {
  position: relative; z-index: 1;
  max-width: 600px; text-align: center;
  display: flex; flex-direction: column; align-items: center; gap: 0;
}
.h-404-eyebrow {
  font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .1em; color: var(--lime);
  margin-bottom: 18px;
}
.h-404-h1 {
  font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600;
  font-size: clamp(52px,9vw,110px); line-height: .92;
  letter-spacing: -.04em; margin: 0 0 24px; color: var(--ink);
}
.h-404-lead {
  font-size: clamp(16px,1.4vw,18px); color: var(--ink-2);
  max-width: 440px; line-height: 1.65; margin: 0 0 36px;
}
.h-404-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-bottom: 36px; }
.h-btn-primary {
  display: inline-flex; align-items: center; gap: 9px;
  padding: 14px 22px; background: var(--green); color: var(--bg);
  text-decoration: none; border-radius: 12px;
  font-weight: 600; font-size: 15px;
  box-shadow: 0 0 0 1px var(--green-deep), 0 12px 30px -8px color-mix(in srgb, var(--green) 55%, transparent);
  transition: background .18s ease, box-shadow .2s ease;
}
.h-btn-primary:hover { background: var(--lime); box-shadow: 0 0 0 1px var(--lime), 0 14px 36px -8px color-mix(in srgb, var(--lime) 65%, transparent); }
.h-btn-primary svg { width: 17px; height: 17px; }
.h-btn-ghost {
  display: inline-flex; align-items: center; gap: 9px;
  padding: 14px 22px; border: 1px solid var(--line-2);
  background: var(--panel); color: var(--ink);
  text-decoration: none; border-radius: 12px;
  font-weight: 500; font-size: 15px;
  transition: background .18s ease, border-color .18s ease;
}
.h-btn-ghost:hover { background: var(--panel-2); border-color: var(--green); }
.h-404-links {
  display: flex; flex-wrap: wrap; align-items: center; gap: 6px 14px;
  justify-content: center;
  font-family: 'Space Mono', monospace; font-size: 12px; color: var(--mute);
}
.h-404-links a {
  color: var(--ink-2); text-decoration: none;
  padding: 5px 12px; border: 1px solid var(--line); border-radius: 999px;
  background: var(--panel); font-size: 12px;
  transition: border-color .15s ease, color .15s ease, background .15s ease;
}
.h-404-links a:hover { border-color: var(--green); color: var(--green); background: var(--lime-soft); }

@media(max-width:480px) {
  .h-404-h1 { font-size: clamp(44px, 14vw, 64px); }
  .h-404-actions { flex-direction: column; width: 100%; }
  .h-btn-primary, .h-btn-ghost { justify-content: center; width: 100%; }
}
</style>
