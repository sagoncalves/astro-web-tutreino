---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../utils/meta';
---

<Layout title={`404 — ${SITE_CONFIG.name}`} description="Página no encontrada." robots="noindex, nofollow">
  <div class="mx-auto flex max-w-lg flex-col items-center px-4 py-24 text-center">
    <p class="text-sm font-medium text-sky-600">404</p>
    <h1 class="mt-2 text-2xl font-semibold text-slate-900">No encontramos esta página</h1>
    <p class="mt-3 text-slate-600">Revisá la URL o volvé al inicio.</p>
    <a
      href="/"
      class="mt-8 inline-flex rounded-full bg-sky-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-sky-700"
    >
      Ir al inicio
    </a>
  </div>
</Layout>
