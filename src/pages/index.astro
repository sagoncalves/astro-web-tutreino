  <script>
    // billing toggle
    const billOpts = document.querySelectorAll('.h-bill-opt');
    const amounts = document.querySelectorAll('.h-amt[data-mensual]');
    const anualNotes = document.querySelectorAll('.h-vprice-anual');
    billOpts.forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.getAttribute('data-bill');
        billOpts.forEach((b) => {
          const on = b === btn;
          b.classList.toggle('active', on);
          b.setAttribute('aria-pressed', String(on));
        });
        amounts.forEach((a) => {
          const v = a.getAttribute(`data-${mode}`);
          if (v) a.textContent = v;
        });
        anualNotes.forEach((n) => { n.hidden = mode !== 'anual'; });
      });
    });
  </script>
