---
// Brand H: brand-a content × v2 aesthetic
// Dark green palette, grid bg, glows, Bricolage+Geist+JetBrains, floating pill nav
// Content: tutreino — gym/personal-trainer SaaS with admin panel + member-facing app,
// multi-branch, white label (Pro), AI routines, churn prediction, role permissions
import SiteLayout from '../layouts/SiteLayout.astro';
import { createPageMeta, PAGE_META, SITE_CONFIG } from '../utils/meta';
const metaData = createPageMeta('/', PAGE_META.home);
const registroUrl = SITE_CONFIG.appRegistrationUrl;
const waNumber = '59891961610';
const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent('Hola, quiero agendar una demo de tutreino para mi gimnasio.')}`;
---
<SiteLayout {...metaData} home>

  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "tutreino",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Sistema de gestión para gimnasios de una o varias sucursales y entrenadores personales: reservas, pagos recurrentes, rutinas con inteligencia artificial, predicción de bajas y app propia (con white label) para que los socios entrenen, paguen y sigan su progreso.",
    "offers": [
      {
        "@type": "Offer",
        "name": "Starter",
        "price": "1800",
        "priceCurrency": "UYU",
        "description": "Hasta 50 socios, una sucursal, reservas de clases, pagos recurrentes y por transferencia, app para socios"
      },
      {
        "@type": "Offer",
        "name": "Pro",
        "price": "3200",
        "priceCurrency": "UYU",
        "description": "Socios y sucursales ilimitadas, app con white label, rutinas con IA y periodización automática, predicción de bajas, permisos por rol, seguimiento de lesiones y progreso"
      }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": "120"
    }
  })} />

  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Qué es tutreino exactamente?",
        "acceptedAnswer": { "@type": "Answer", "text": "Es un sistema de gestión para gimnasios y entrenadores personales, disponible como SaaS en app.tutreino.com. Incluye un panel administrativo para tu equipo y una app propia donde tus socios reservan clases, pagan, siguen su rutina y registran su progreso." }
      },
      {
        "@type": "Question",
        "name": "¿Sirve para gimnasios con varias sucursales?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sí. Podés gestionar múltiples sedes desde una sola cuenta: agenda, staff, socios y métricas separados por sucursal, con visión consolidada para los administradores generales." }
      },
      {
        "@type": "Question",
        "name": "¿Qué es el white label del plan Pro?",
        "acceptedAnswer": { "@type": "Answer", "text": "En el plan Pro, la app que usan tus socios se personaliza completamente con tu marca: tu logo, tus colores y tu nombre, sin ninguna referencia a tutreino. Ideal para gimnasios grandes que quieren su propia identidad." }
      },
      {
        "@type": "Question",
        "name": "¿Cómo funcionan las rutinas con inteligencia artificial?",
        "acceptedAnswer": { "@type": "Answer", "text": "El sistema genera rutinas personalizadas según el objetivo, nivel y progreso de cada socio, y las periodiza automáticamente semana a semana. El entrenador puede ajustarlas, combinarlas con su criterio o publicarlas tal cual." }
      },
      {
        "@type": "Question",
        "name": "¿Qué pueden hacer los socios desde su app?",
        "acceptedAnswer": { "@type": "Answer", "text": "Reservar clases, pagar membresías (incluyendo pagos recurrentes y por transferencia), ver y seguir su rutina, registrar su progreso y completar formularios de intake, lesiones y satisfacción." }
      },
      {
        "@type": "Question",
        "name": "¿Puedo crear usuarios para mis entrenadores y otros administradores?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sí. Podés crear cuentas para entrenadores, recepcionistas u otros administradores, y asignarles permisos según su rol." }
      },
      {
        "@type": "Question",
        "name": "¿Cómo ayuda tutreino a reducir las bajas de socios?",
        "acceptedAnswer": { "@type": "Answer", "text": "El sistema analiza asistencia, pagos y respuestas de satisfacción para identificar socios en riesgo de darse de baja, y te avisa antes de que pase para que puedas actuar a tiempo." }
      },
      {
        "@type": "Question",
        "name": "¿Puedo probarlo antes de pagar?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sí, 30 días gratis y sin tarjeta. Si no te convence, no pagás nada y conservás todos tus datos." }
      }
    ]
  })} />

    <!-- hero — white label: tu app, tu marca -->
    <header class="h-section h-wl h-wl-hero" id="inicio">
      <div class="h-head h-head-center">
        <div class="h-meta-strip h-wl-meta">
          <span><span class="h-tag-id">●</span> +120 gimnasios y entrenadores</span>
        </div>
        <h1 class="h-h1">Tu app.<br/><span class="h-grad">Tu marca.</span></h1>
        <p class="h-sub h-sub-center">Tus socios reservan, pagan y ven su rutina desde una app que dice <b>tu nombre</b>, con <b>tu logo</b> y <b>tus colores</b>. Vos manejás todo desde un solo panel.</p>
      </div>

      <div class="h-wl-grid">
        <!-- Gimnasio 1 — Azul -->
        <figure class="h-phone" style="--brand:#1d4ed8;--brand-2:#3b82f6;--brand-soft:#dbeafe;">
          <div class="h-phone-frame">
            <div class="h-phone-notch"></div>
            <div class="h-phone-screen">
              <div class="h-app-top">
                <span class="h-app-logo"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h3v16H6zm9 0h3v16h-3zM4 9h16v6H4z"/></svg>IRON HOUSE</span>
              </div>
              <div class="h-app-hero">Hola, Marcos 👊</div>
              <div class="h-app-card primary">Tu clase de hoy<br/><b>Funcional · 19:00</b></div>
              <div class="h-app-card">Próximo pago<br/><b>en 6 días · automático</b></div>
              <div class="h-app-nav"><span class="on"></span><span></span><span></span><span></span></div>
            </div>
          </div>
        </figure>

        <!-- Gimnasio 2 — Verde -->
        <figure class="h-phone featured" style="--brand:#059669;--brand-2:#10b981;--brand-soft:#d1fae5;">
          <div class="h-phone-frame">
            <div class="h-phone-notch"></div>
            <div class="h-phone-screen">
              <div class="h-app-top">
                <span class="h-app-logo"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 7v10l8 5 8-5V7zm0 4 4 2.5v5L12 16l-4-2.5v-5z"/></svg>ZEN STUDIO</span>
              </div>
              <div class="h-app-hero">Hola, Lucía 🌿</div>
              <div class="h-app-card primary">Tu clase de hoy<br/><b>Yoga Flow · 08:00</b></div>
              <div class="h-app-card">Tu rutina<br/><b>generada con IA</b></div>
              <div class="h-app-nav"><span class="on"></span><span></span><span></span><span></span></div>
            </div>
          </div>
        </figure>

        <!-- Gimnasio 3 — Naranja -->
        <figure class="h-phone" style="--brand:#ea580c;--brand-2:#f97316;--brand-soft:#ffedd5;">
          <div class="h-phone-frame">
            <div class="h-phone-notch"></div>
            <div class="h-phone-screen">
              <div class="h-app-top">
                <span class="h-app-logo"><svg viewBox="0 0 24 24" fill="currentColor"><path d="m13 2-9 12h7l-2 8 9-12h-7z"/></svg>FLOW GYM</span>
              </div>
              <div class="h-app-hero">Hola, Diego ⚡</div>
              <div class="h-app-card primary">Tu clase de hoy<br/><b>Spinning · 20:30</b></div>
              <div class="h-app-card">Tu progreso<br/><b>+4kg este mes</b></div>
              <div class="h-app-nav"><span class="on"></span><span></span><span></span><span></span></div>
            </div>
          </div>
        </figure>
      </div>
    </header>

    <!-- producto — feature blocks que venden resultados -->
    <section class="h-section" id="producto">
      <div class="h-head">
        <h2 class="h-h2">Un sistema.<br/><span class="h-grad">Todo tu gimnasio.</span></h2>
        <p class="h-sub">No es una planilla con más botones. Es el sistema que cobra solo, retiene socios y entrena por vos — con tu marca adelante.</p>
      </div>

      <!-- BLOQUE 1 — Cobros -->
      <div class="h-feat" id="cobros">
        <div class="h-feat-copy">
          <h3 class="h-feat-h">Cobrás sin perseguir<br/>a nadie.</h3>
          <p class="h-feat-lead">Recordatorio, link de pago y confirmación salen solos. Vos abrís el panel y el dinero ya entró — débito automático, transferencia o tarjeta.</p>
          <ul class="h-feat-pts">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg><span><b>Más cobranza puntual.</b> Se acabó el "te pago la semana que viene".</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg><span><b>Cero recepción.</b> El socio paga desde su app, no en el mostrador.</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg><span><b>Planes a medida.</b> Mensual, anual, pase libre o por clase.</span></li>
          </ul>
        </div>

        <!-- mockup: panel de cobros -->
        <div class="h-feat-vis">
          <div class="h-screen-body">
            <div class="h-stat-row">
              <div class="h-stat">
                <span class="h-stat-lbl">Ingreso del mes</span>
                <span class="h-stat-val">$ 2.847.500</span>
                <span class="h-stat-trend up">▲ 18% vs. mes anterior</span>
              </div>
              <div class="h-stat">
                <span class="h-stat-lbl">Cobrado solo</span>
                <span class="h-stat-val">94<small>%</small></span>
                <span class="h-stat-trend">312 de 332 socios</span>
              </div>
            </div>
            <div class="h-pay-list">
              <div class="h-pay"><span class="h-pay-av">MG</span><div class="h-pay-body"><b>Marcos G.</b><small>Plan Pro · débito automático</small></div><span class="h-pay-amt ok">$ 18.500 ✓</span></div>
              <div class="h-pay"><span class="h-pay-av">LR</span><div class="h-pay-body"><b>Lucía R.</b><small>Mensual · link enviado</small></div><span class="h-pay-amt wait">$ 14.000 ⏳</span></div>
              <div class="h-pay"><span class="h-pay-av">DC</span><div class="h-pay-body"><b>Diego C.</b><small>Anual · transferencia</small></div><span class="h-pay-amt ok">$ 162.000 ✓</span></div>
              <div class="h-pay"><span class="h-pay-av">AT</span><div class="h-pay-body"><b>Ana T.</b><small>Plan Pro · débito automático</small></div><span class="h-pay-amt ok">$ 18.500 ✓</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- BLOQUE 2 — Retención + IA (mockup a la izquierda) -->
      <div class="h-feat reverse" id="retencion">
        <div class="h-feat-copy">
          <h3 class="h-feat-h">Sabés quién se va<br/>antes de que se vaya.</h3>
          <p class="h-feat-lead">El sistema lee asistencia, pagos y uso, y te avisa qué socios están por darse de baja — con tiempo para hacer algo. Y arma las rutinas que los mantienen enganchados.</p>
          <ul class="h-feat-pts">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg><span><b>Alertas de riesgo de baja</b> antes de que dejen de venir.</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg><span><b>Rutinas con IA en segundos,</b> periodizadas por objetivo y nivel.</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg><span><b>El entrenador ajusta,</b> la IA hace el trabajo pesado.</span></li>
          </ul>
        </div>

        <!-- mockup: alerta de retención -->
        <div class="h-feat-vis">
          <div class="h-screen-body">
            <div class="h-alert">
              <div class="h-alert-head"><span class="h-alert-pulse"></span><b>4 socios en riesgo de baja</b></div>
              <p>No asisten hace 12+ días y su pago vence pronto. Contactalos ahora.</p>
            </div>
            <div class="h-risk">
              <div class="h-risk-row"><span class="h-pay-av">SF</span><div class="h-pay-body"><b>Sofía F.</b><small>Sin venir hace 14 días</small></div><span class="h-risk-tag hi">riesgo alto</span></div>
              <div class="h-risk-row"><span class="h-pay-av">NM</span><div class="h-pay-body"><b>Nahuel M.</b><small>Asistencia ↓ 60%</small></div><span class="h-risk-tag hi">riesgo alto</span></div>
              <div class="h-risk-row"><span class="h-pay-av">VP</span><div class="h-pay-body"><b>Valentina P.</b><small>Pago vence en 2 días</small></div><span class="h-risk-tag md">riesgo medio</span></div>
            </div>
            <div class="h-ai-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v3m0 12v3M3 12h3m12 0h3m-2.5-6.5-2 2m-9 9-2 2m0-13 2 2m9 9 2 2"/></svg>
              <span>IA generó <b>3 rutinas nuevas</b> para reactivarlos</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- experiencia del socio -->
    <section class="h-section" id="socios">
      <div class="h-head">
        <span class="h-eyebrow">Del lado del socio</span>
        <h2 class="h-h2">Tus socios hacen<br/><span class="h-grad">todo desde el celular.</span></h2>
        <p class="h-sub">Sin grupos de WhatsApp ni planillas. Reservan, pagan y entrenan desde su app — y vos te enterás de todo en el panel.</p>
      </div>
      <div class="h-journey">
        <div class="h-jstep">
          <div class="h-jstep-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4m8-4v4" stroke-linecap="round"/></svg>
          </div>
          <h3>Reserva su clase</h3>
          <p>Ve los horarios con cupo en vivo y reserva en dos toques. Si se llena, entra a lista de espera automática.</p>
        </div>
        <div class="h-jline" aria-hidden="true"></div>
        <div class="h-jstep">
          <div class="h-jstep-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="m6 13 3 3 9-9" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9.5"/></svg>
          </div>
          <h3>Entrena con su rutina</h3>
          <p>Abre la rutina que armó la IA, marca cada ejercicio y registra su progreso. El entrenador lo ve al instante.</p>
        </div>
        <div class="h-jline" aria-hidden="true"></div>
        <div class="h-jstep">
          <div class="h-jstep-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20M6 15h4" stroke-linecap="round"/></svg>
          </div>
          <h3>Paga sin pensarlo</h3>
          <p>Su membresía se renueva sola con débito automático. Sin filas en recepción ni recordatorios incómodos.</p>
        </div>
      </div>
    </section>

    <!-- flujo — v2 numbered steps -->
    <section class="h-section" id="flujo">
      <div class="h-head">
        <span class="h-eyebrow">Tu puesta en marcha</span>
        <h2 class="h-h2">En un día,<br/><span class="h-grad">listo para siempre.</span></h2>
      </div>
      <ol class="h-flow">
        <li>
          <div class="h-flow-num" data-n="01">01</div>
          <div class="h-flow-card">
            <h3>Configurás tu gimnasio</h3>
            <p>Cargás sucursales, planes, horarios y permisos para tu equipo. Si tenés varias sedes, cada una con su propia agenda y staff.</p>
            <div class="h-flow-tags">
              <span class="h-flow-tag">2 sucursales</span>
              <span class="h-flow-tag">Horarios</span>
              <span class="h-flow-tag">Permisos de equipo</span>
            </div>
          </div>
        </li>
        <li>
          <div class="h-flow-num" data-n="02">02</div>
          <div class="h-flow-card">
            <h3>Invitás a tus socios</h3>
            <p>Importás tu base desde Excel o los invitás uno a uno. Cada socio entra a su propia app: reserva, paga y carga su ficha de salud y objetivos.</p>
            <div class="h-flow-tags">
              <span class="h-flow-tag">248 socios importados</span>
              <span class="h-flow-tag success">Invitaciones enviadas ✓</span>
            </div>
          </div>
        </li>
        <li>
          <div class="h-flow-num" data-n="03">03</div>
          <div class="h-flow-card">
            <h3>La plataforma escala con vos</h3>
            <p>Cobros recurrentes, recordatorios, reservas, rutinas con IA y alertas de bajas. Tu equipo decide; el sistema hace el trabajo repetitivo.</p>
            <div class="h-flow-tags">
              <span class="h-flow-tag success">● En vivo</span>
              <span class="h-flow-tag">248 socios activos</span>
              <span class="h-flow-tag">12 rutinas IA generadas hoy</span>
            </div>
          </div>
        </li>
      </ol>
    </section>

    <!-- testimonios -->
    <section class="h-section" id="testimonios">
      <div class="h-head">
        <h2 class="h-h2">Gimnasios que ya<br/><span class="h-grad">dejaron el Excel.</span></h2>
        <p class="h-sub">Más de 120 gimnasios y entrenadores en Uruguay gestionan su negocio con tutreino todos los días.</p>
      </div>
      <div class="h-test-grid">
        <article class="h-test">
          <p>“Lanzamos la app con nuestro logo y nuestros colores y los socios la sintieron como propia desde el día uno. Las rutinas con IA nos ahorran horas de planificación cada semana.”</p>
          <footer>
            <span class="h-test-av" style="background:rgba(29,78,216,.12);color:#1d4ed8">R</span>
            <div><div class="h-test-name">Rodrigo Silva</div><div class="h-test-role">Dueño · Iron Gym, Montevideo</div></div>
          </footer>
        </article>
        <article class="h-test">
          <p>“Manejo tres sucursales y antes era un caos coordinar todo por WhatsApp. Ahora veo cada sede por separado y también junta: ocupación, cobros, permisos del staff y alertas de socios en riesgo de baja.”</p>
          <footer>
            <span class="h-test-av" style="background:rgba(124,58,237,.12);color:#7c3aed">V</span>
            <div><div class="h-test-name">Valentina Praderi</div><div class="h-test-role">Gerente · Núcleo Fitness, Canelones</div></div>
          </footer>
        </article>
        <article class="h-test">
          <p>“Soy entrenador personal y no tenía tiempo para armar rutinas desde cero. La IA arma una base sólida según el objetivo de cada cliente, yo la ajusto con mi criterio y listo. Y los cobros recurrentes ya no dependen de que yo me acuerde.”</p>
          <footer>
            <span class="h-test-av" style="background:rgba(5,150,105,.12);color:#059669">F</span>
            <div><div class="h-test-name">Federico Acosta</div><div class="h-test-role">Entrenador personal · Punta del Este</div></div>
          </footer>
        </article>
      </div>
    </section>

    <!-- comparativa -->
    <section class="h-section" id="comparativa">
      <div class="h-head">
        <h2 class="h-h2">Planillas y grupos<br/><span class="h-grad">tienen un techo.</span></h2>
        <p class="h-sub">Excel, WhatsApp y libretas no escalan ni te dan una app para tus socios. Así se compara tu día a día actual con tutreino.</p>
      </div>
      <div class="h-cmp-table" role="table" aria-label="Comparación entre gestión manual y tutreino">
        <div class="h-cmp-row h-cmp-head" role="row">
          <span role="columnheader"><span class="sr-only">Característica</span></span>
          <span role="columnheader">Planillas + WhatsApp</span>
          <span role="columnheader" class="h-cmp-hl">tutreino</span>
        </div>
        <div class="h-cmp-row" role="row">
          <span role="cell">Experiencia para tus socios</span>
          <span role="cell" class="h-cmp-no">Mensajes sueltos, sin un lugar propio</span>
          <span role="cell" class="h-cmp-yes">App propia, con tu marca en el plan Pro</span>
        </div>
        <div class="h-cmp-row" role="row">
          <span role="cell">Cobro de membresías</span>
          <span role="cell" class="h-cmp-no">Manual, mes a mes</span>
          <span role="cell" class="h-cmp-yes">Recurrente, por tarjeta o transferencia</span>
        </div>
        <div class="h-cmp-row" role="row">
          <span role="cell">Reserva de clases y turnos</span>
          <span role="cell" class="h-cmp-no">Grupos de WhatsApp, planillas</span>
          <span role="cell" class="h-cmp-yes">Agenda online desde la app del socio</span>
        </div>
        <div class="h-cmp-row" role="row">
          <span role="cell">Rutinas de entrenamiento</span>
          <span role="cell" class="h-cmp-no">Hojas sueltas, sin seguimiento</span>
          <span role="cell" class="h-cmp-yes">Generadas con IA, periodizadas y con progreso</span>
        </div>
        <div class="h-cmp-row" role="row">
          <span role="cell">Gimnasios con varias sucursales</span>
          <span role="cell" class="h-cmp-no">Información dispersa por sede</span>
          <span role="cell" class="h-cmp-yes">Vista consolidada y por sucursal</span>
        </div>
        <div class="h-cmp-row" role="row">
          <span role="cell">Anticipación a las bajas</span>
          <span role="cell" class="h-cmp-no">Te enterás cuando ya se fueron</span>
          <span role="cell" class="h-cmp-yes">Alertas de riesgo antes de que pase</span>
        </div>
      </div>
    </section>

    <!-- medios de pago -->
    <section class="h-section" id="pagos">
      <div class="h-pagos-layout">
        <div class="h-head h-pagos-head">
          <h2 class="h-h2">Cobrás como<br/><span class="h-grad">tus socios prefieren.</span></h2>
