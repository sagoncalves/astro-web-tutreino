.h-ai-chip { display: flex; align-items: center; gap: 10px; background: var(--lime-soft); border: 1px solid color-mix(in srgb, var(--lime) 35%, transparent); border-radius: 11px; padding: 11px 13px; font-size: 13px; color: var(--green-deep); }
.h-ai-chip b { color: var(--green); }
.h-ai-chip svg { width: 18px; height: 18px; flex-shrink: 0; color: var(--lime); }

/* ── white label showcase ─────────────────────────── */
.h-wl { background: linear-gradient(180deg, transparent, var(--bg-2) 40%, transparent); }
/* white-label hero — first section under the sticky nav */
.h-wl-hero { padding-top: clamp(28px,5vw,56px); }
.h-wl-hero .h-h1 { font-size: clamp(48px,9vw,110px); }
.h-wl-hero .h-sub-center { font-size: clamp(17px,1.5vw,20px); max-width: 600px; }
.h-wl-meta { justify-content: center; margin-bottom: 22px; }
/* fanned out like a hand of cards — at every screen size */
.h-wl-grid { display: flex; justify-content: center; align-items: flex-end; flex-wrap: nowrap; perspective: 1400px; margin-top: 24px; }
.h-phone { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 16px; }
.h-phone-frame {
  width: 230px; height: 470px; background: #0b0f17; border-radius: 38px; padding: 9px;
  box-shadow: 0 36px 70px -30px rgba(15,22,35,.4), inset 0 0 0 1.5px rgba(255,255,255,.06);
  position: relative; transform-origin: bottom center; transition: transform .5s cubic-bezier(.22,1,.36,1);
}
/* left card: tilt left, tucked behind */
.h-phone:nth-child(1) { z-index: 1; margin-right: -40px; }
.h-phone:nth-child(1) .h-phone-frame { transform: rotate(-9deg) translateY(12px); }
/* center (featured): upright, raised, on top */
.h-phone.featured { z-index: 3; }
.h-phone.featured .h-phone-frame { transform: translateY(-18px) scale(1.04); box-shadow: 0 48px 90px -32px color-mix(in srgb, var(--brand) 45%, rgba(15,22,35,.4)); }
/* right card: tilt right, tucked behind */
.h-phone:nth-child(3) { z-index: 2; margin-left: -40px; }
.h-phone:nth-child(3) .h-phone-frame { transform: rotate(9deg) translateY(12px); }
/* hover lifts each card out of the fan without losing its tilt */
.h-phone:nth-child(1) .h-phone-frame:hover { transform: rotate(-9deg) translateY(-2px); }
.h-phone.featured .h-phone-frame:hover { transform: translateY(-30px) scale(1.04); }
.h-phone:nth-child(3) .h-phone-frame:hover { transform: rotate(9deg) translateY(-2px); }
.h-phone-notch { position: absolute; top: 9px; left: 50%; transform: translateX(-50%); width: 92px; height: 22px; background: #0b0f17; border-radius: 0 0 14px 14px; z-index: 3; }
.h-phone-screen { width: 100%; height: 100%; background: var(--brand-soft); border-radius: 30px; overflow: hidden; display: flex; flex-direction: column; padding: 38px 16px 16px; gap: 12px; }
.h-app-top { display: flex; align-items: center; }
.h-app-logo { display: inline-flex; align-items: center; gap: 7px; font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 14px; letter-spacing: -.02em; color: var(--brand); }
.h-app-logo svg { width: 18px; height: 18px; }
.h-app-hero { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; font-size: 19px; color: #0f1623; letter-spacing: -.02em; }
.h-app-card { background: #fff; border-radius: 15px; padding: 13px 14px; font-size: 11.5px; color: #64748b; line-height: 1.5; box-shadow: 0 4px 14px -8px rgba(15,22,35,.25); }
.h-app-card b { display: block; font-size: 14px; color: #0f1623; margin-top: 2px; }
.h-app-card.primary { background: var(--brand); color: rgba(255,255,255,.85); }
.h-app-card.primary b { color: #fff; }
.h-app-nav { margin-top: auto; display: flex; justify-content: center; gap: 22px; padding-top: 8px; }
.h-app-nav span { width: 7px; height: 7px; border-radius: 50%; background: rgba(15,22,35,.18); }
.h-app-nav span.on { background: var(--brand); width: 18px; border-radius: 999px; }
@media(max-width:760px) {
  .h-stat-row { grid-template-columns: 1fr; }

  /* white label: tighten gap between heading and phone fan */
  .h-wl .h-head { margin-bottom: 16px; }

  /* white label phones: same fan, but pulled tighter and centered for narrow screens */
  .h-wl-grid { padding: 0 0 8px; transform: scale(.8); transform-origin: center bottom; }
  .h-phone { gap: 0; }
  /* tighter overlap so the three cards stay centered in the viewport */
  .h-phone:nth-child(1) { margin-right: -88px; }
  .h-phone:nth-child(3) { margin-left: -88px; }
  /* freeze hover so a touch doesn't make a card jump out of the fan */
  .h-phone:nth-child(1) .h-phone-frame:hover { transform: rotate(-9deg) translateY(12px); }
  .h-phone.featured .h-phone-frame:hover { transform: translateY(-18px) scale(1.04); }
  .h-phone:nth-child(3) .h-phone-frame:hover { transform: rotate(9deg) translateY(12px); }
}
@media(prefers-reduced-motion: reduce) {
  .h-screen-body, .h-phone-frame { transition: none; }
  .h-alert-pulse { animation: none; }
}

/* flow as a vertical timeline */
.h-flow { --node: 64px; --col: 84px; list-style: none; padding: 0; margin: 0; display: grid; gap: 28px; }
.h-flow li { position: relative; display: grid; grid-template-columns: var(--col) 1fr; gap: 24px; align-items: start; }
/* connecting line: from this node's centre down to the next node (covers the gap) */
.h-flow li:not(:last-child)::before {
  content: ""; position: absolute;
  top: calc(var(--node) / 2); height: calc(100% - var(--node) / 2 + 28px);
  left: calc(var(--col) / 2); width: 2px; transform: translateX(-50%);
  background: linear-gradient(180deg, var(--green), var(--lime));
}
/* node: circular badge holding the gradient number, sits on the line */
.h-flow-num {
  position: relative; z-index: 1; justify-self: center;
  width: var(--node); height: var(--node); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: var(--panel); border: 2px solid var(--line-2);
  box-shadow: 0 6px 18px -8px rgba(15,22,35,.18);
  font-family: 'Bricolage Grotesque', sans-serif; font-size: 24px; font-weight: 700; letter-spacing: -.02em; line-height: 1;
  background-clip: padding-box;
  color: transparent; -webkit-text-fill-color: transparent;
}
/* gradient digits via an inner layer so the circle keeps its solid bg */
.h-flow-num::after {
  content: attr(data-n); position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(120deg, var(--green) 0%, var(--lime) 60%, var(--green) 100%);
  -webkit-background-clip: text; background-clip: text;
  -webkit-text-fill-color: transparent; color: transparent;
}
@media(max-width:520px) {
  .h-flow { --node: 44px; --col: 56px; gap: 20px; }
  .h-flow li { gap: 14px; }
  .h-flow-num { font-size: 17px; border-width: 1.5px; }
  .h-flow-card { padding: 20px 18px; border-radius: 14px; }
  .h-flow-card h3 { font-size: 19px; }
  .h-flow-card p { font-size: 14px; }
}
.h-flow-card { background: var(--panel); border: 1px solid var(--line); border-radius: 16px; padding: 28px; transition: border-color .2s ease; }
.h-flow-card:hover { border-color: var(--green); }
.h-flow-card h3 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; font-size: 24px; margin: 0 0 8px; letter-spacing: -.02em; }
.h-flow-card p { color: var(--ink-2); margin: 0 0 16px; font-size: 15px; }
.h-flow-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
.h-flow-tag { display: inline-flex; align-items: center; gap: 6px; font-family: 'Bricolage Grotesque', sans-serif; font-size: 13px; font-weight: 500; color: var(--ink-2); background: var(--panel-2); padding: 8px 14px; border-radius: 100px; border: 1px solid var(--line); }
.h-flow-tag.success { color: var(--lime); background: var(--lime-soft); border-color: var(--lime); }

/* pricing — v2 style */
.h-price-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; max-width: 920px; margin: 0 auto; }
@media(max-width:720px) { .h-price-grid { grid-template-columns: 1fr; } }
.h-vprice { background: var(--panel); border: 1px solid var(--line); border-radius: 22px; padding: 32px; display: flex; flex-direction: column; gap: 22px; position: relative; overflow: hidden; transition: transform .25s ease, border-color .2s ease; }
.h-vprice:hover { transform: translateY(-4px); border-color: var(--green); }
.h-vprice-featured { background: var(--bg-2); border-color: var(--green); box-shadow: 0 0 0 1px var(--green-deep), 0 30px 80px -30px color-mix(in srgb, var(--green) 50%, transparent); }
.h-vprice-glow { position: absolute; width: 380px; height: 380px; background: radial-gradient(circle, var(--lime) 0%, transparent 65%); top: -150px; right: -150px; opacity: .15; pointer-events: none; }
.h-vprice-head h3 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; font-size: 26px; margin: 0 0 4px; letter-spacing: -.02em; display: flex; align-items: center; gap: 10px; }
.h-hot { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--bg); background: var(--lime); padding: 3px 8px; border-radius: 999px; text-transform: uppercase; font-weight: 700; letter-spacing: .05em; }
.h-vprice-tag { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--mute); }
.h-vprice-amount { display: flex; align-items: baseline; gap: 6px; font-family: 'Bricolage Grotesque', sans-serif; }
.h-cur { font-size: 14px; color: var(--mute); font-family: 'Space Mono', monospace; }
.h-amt { font-size: 56px; font-weight: 600; line-height: 1; letter-spacing: -.04em; }
.h-per { font-size: 14px; color: var(--mute); font-family: 'Space Mono', monospace; }
.h-vprice ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.h-vprice li { font-size: 14.5px; color: var(--ink-2); padding-left: 24px; position: relative; }
.h-vprice li::before { content: ''; position: absolute; left: 0; top: 8px; width: 12px; height: 7px; border-left: 2px solid var(--green); border-bottom: 2px solid var(--green); transform: rotate(-45deg); }
.h-vprice-cta { margin-top: auto; display: inline-flex; align-items: center; justify-content: center; padding: 14px 22px; border-radius: 12px; background: var(--panel-2); color: var(--ink); border: 1px solid var(--line-2); text-decoration: none; font-weight: 500; transition: background .18s ease, border-color .18s ease; cursor: pointer; }
.h-vprice-cta:hover { background: var(--bg); border-color: var(--green); }
.h-vprice-cta.primary { background: var(--green); color: var(--bg); border-color: var(--green); font-weight: 600; }
.h-vprice-cta.primary:hover { background: var(--lime); border-color: var(--lime); }

/* testimonios */
.h-test-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
.h-test { background: var(--panel); border: 1px solid var(--line); border-radius: 18px; padding: 26px; display: flex; flex-direction: column; gap: 20px; transition: border-color .2s ease, background .2s ease; }
.h-test:hover { border-color: var(--green); background: var(--panel-2); }
.h-test p { margin: 0; color: var(--ink-2); font-size: 14.5px; line-height: 1.6; }
.h-test footer { display: flex; align-items: center; gap: 12px; }
.h-test-av { width: 36px; height: 36px; border-radius: 999px; display: grid; place-items: center; font-weight: 700; font-size: 14px; flex-shrink: 0; font-family: 'Bricolage Grotesque', sans-serif; }
.h-test-name { font-size: 13.5px; font-weight: 600; color: var(--ink); }
.h-test-role { font-size: 11.5px; color: var(--mute); margin-top: 1px; }

@media(max-width:900px) {
  .h-test-grid {
    display: flex;
    overflow: hidden;
    position: relative;
    min-height: 220px;
  }
  .h-test {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateX(40px);
    transition: none;
    animation: h-slide 12s infinite;
  }
  .h-test:nth-child(1) { animation-delay: 0s; }
  .h-test:nth-child(2) { animation-delay: 4s; }
  .h-test:nth-child(3) { animation-delay: 8s; }
  @keyframes h-slide {
    0%   { opacity: 0; transform: translateX(40px); }
    5%   { opacity: 1; transform: translateX(0); }
    28%  { opacity: 1; transform: translateX(0); }
    33%  { opacity: 0; transform: translateX(-40px); }
    100% { opacity: 0; transform: translateX(-40px); }
  }
}

/* comparativa */
.h-cmp-table { border: 1px solid var(--line); border-radius: 18px; overflow: hidden; background: var(--panel); }
.h-cmp-row { display: grid; grid-template-columns: 1.2fr 1fr 1fr; }
.h-cmp-row + .h-cmp-row { border-top: 1px solid var(--line); }
.h-cmp-row span { padding: 16px 20px; font-size: 14px; display: flex; align-items: center; }
.h-cmp-head span { font-family: 'Space Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: var(--mute); }
.h-cmp-head .h-cmp-hl { color: var(--green); background: color-mix(in srgb, var(--green) 8%, transparent); }
.h-cmp-row span:first-child { font-weight: 500; color: var(--ink); }
.h-cmp-no { color: var(--mute); }
.h-cmp-yes { color: var(--green); font-weight: 500; }
.h-cmp-yes::before { content: ''; flex-shrink: 0; width: 14px; height: 8px; margin-right: 10px; border-left: 2px solid var(--green); border-bottom: 2px solid var(--green); transform: rotate(-45deg) translateY(-2px); }
@media(max-width:720px) {
  .h-cmp-table { border: none; background: none; border-radius: 0; overflow: visible; display: flex; flex-direction: column; gap: 10px; }
  .h-cmp-head { display: none; }
  .h-cmp-row { display: flex; flex-direction: column; background: var(--panel); border: 1px solid var(--line); border-radius: 14px; overflow: hidden; padding: 0; }
  .h-cmp-row + .h-cmp-row { border-top: 1px solid var(--line); }
  .h-cmp-row span { padding: 0; }
  .h-cmp-row span:first-child { font-size: 11px; font-family: 'Space Mono', monospace; text-transform: uppercase; letter-spacing: .05em; color: var(--mute); font-weight: 500; padding: 12px 16px 8px; border-bottom: 1px solid var(--line); }
  .h-cmp-row .h-cmp-no,
  .h-cmp-row .h-cmp-yes { font-size: 13px; padding: 10px 16px; display: flex; align-items: flex-start; gap: 8px; }
  .h-cmp-row .h-cmp-no { color: var(--mute); border-bottom: 1px solid var(--line); }
  .h-cmp-row .h-cmp-no::before { content: '✕'; flex-shrink: 0; font-size: 11px; margin-top: 1px; opacity: .5; }
  .h-cmp-row .h-cmp-yes { color: var(--green); background: color-mix(in srgb, var(--green) 5%, transparent); }
  .h-cmp-yes::before { content: ''; flex-shrink: 0; width: 12px; height: 7px; margin-top: 4px; border-left: 2px solid var(--green); border-bottom: 2px solid var(--green); transform: rotate(-45deg) translateY(-2px); }
}

/* integraciones */
.h-pagos-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
.h-pagos-head { margin-bottom: 0; max-width: 100%; }
.h-pagos-grid { grid-template-columns: repeat(2,1fr) !important; }
.h-int-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; }
@media(max-width:960px) {
  .h-pagos-layout { grid-template-columns: 1fr; gap: 36px; }
  .h-pagos-head { margin-bottom: 0; }
  .h-pagos-grid { grid-template-columns: repeat(2,1fr) !important; }
}
@media(max-width:900px) { .h-int-grid { grid-template-columns: repeat(2,1fr); } }
@media(max-width:560px) { .h-int-grid { grid-template-columns: 1fr; } .h-pagos-grid { grid-template-columns: 1fr !important; } }
.h-int { background: var(--panel); border: 1px solid var(--line); border-radius: 16px; padding: 22px; display: flex; align-items: center; gap: 14px; transition: border-color .2s ease, background .2s ease; }
.h-int:hover { border-color: var(--green); background: var(--panel-2); }
.h-int-ic { width: 40px; height: 40px; flex-shrink: 0; border-radius: 10px; display: grid; place-items: center; background: color-mix(in srgb, var(--green) 10%, transparent); color: var(--green); }
.h-int-ic svg { width: 20px; height: 20px; }
.h-int-name { font-size: 14px; font-weight: 600; color: var(--ink); }
.h-int-desc { font-size: 12px; color: var(--mute); margin-top: 2px; }

/* para quién — audiencia */
.h-aud-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 48px; }
.h-aud { background: var(--panel); border: 1px solid var(--line); border-radius: 16px; padding: 24px; display: flex; align-items: flex-start; gap: 16px; transition: border-color .2s ease, background .2s ease; }
.h-aud:hover { border-color: var(--green); background: var(--panel-2); }
.h-aud .h-int-desc { margin-top: 4px; line-height: 1.5; }
@media(max-width:720px) { .h-aud-grid { grid-template-columns: 1fr; } }

/* faq — v2 style */
.h-faq { max-width: 760px; background: var(--panel); border: 1px solid var(--line); border-radius: 18px; overflow: hidden; }
.h-faq-col { display: contents; }
.h-faq details { border-bottom: 1px solid var(--line); }
.h-faq details:last-child { border-bottom: none; }

@media (min-width: 768px) {
  .h-faq { max-width: 1180px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; background: none; border: none; border-radius: 0; overflow: visible; }
  .h-faq-col { display: flex; flex-direction: column; gap: 24px; }
  .h-faq details { background: var(--panel); border: 1px solid var(--line); border-radius: 14px; margin-bottom: 0; }
  .h-faq details:last-child { border-bottom: 1px solid var(--line); }
}
.h-faq summary { padding: 22px 26px; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: 16px; font-family: 'Bricolage Grotesque', sans-serif; font-weight: 500; font-size: 17px; color: var(--ink); transition: background .18s ease; }
.h-faq summary:hover { background: var(--panel-2); }
.h-faq summary::-webkit-details-marker { display: none; }
.h-qid { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--lime); margin-right: 14px; flex-shrink: 0; }
.h-caret { font-family: 'Space Mono', monospace; color: var(--mute); font-size: 18px; margin-left: auto; transition: transform .2s ease; }
.h-faq details[open] .h-caret { transform: rotate(45deg); color: var(--green); }
.h-faq p { padding: 0 26px 22px; color: var(--ink-2); font-size: 15px; margin: 0; }

/* final CTA */
.h-final { position: relative; z-index: 1; margin: 0 clamp(20px,4vw,48px) 60px; padding: clamp(70px,12vw,160px) clamp(28px,6vw,80px); background: var(--panel); border: 1px solid var(--line); border-radius: 32px; text-align: center; overflow: hidden; }
.h-final-bg { position: absolute; inset: 0; background: radial-gradient(circle at 30% 0%, color-mix(in srgb, var(--green) 30%, transparent) 0%, transparent 50%), radial-gradient(circle at 70% 100%, color-mix(in srgb, var(--lime) 25%, transparent) 0%, transparent 50%); pointer-events: none; }
.h-final-inner { position: relative; z-index: 1; }
.h-final-h { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; font-size: clamp(44px,8vw,110px); line-height: .95; letter-spacing: -.04em; margin: 16px 0 22px; }
.h-final p { color: var(--ink-2); font-family: 'Space Mono', monospace; font-size: 14px; margin: 0 0 36px; }

/* ── trust strip ──────────────────────────────────── */
.h-trust {
  display: flex; align-items: center; flex-wrap: wrap; gap: 16px 20px;
  padding: 18px 22px; margin-bottom: 8px;
  background: color-mix(in srgb, var(--panel) 70%, transparent);
  border: 1px solid var(--line); border-radius: 14px;
  backdrop-filter: blur(8px);
}
.h-trust-rating { display: inline-flex; align-items: center; gap: 8px; }
.h-stars { color: var(--lime); font-size: 15px; letter-spacing: 1px; }
.h-trust-num { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; font-size: 17px; color: var(--ink); letter-spacing: -.02em; }
.h-trust-lbl { font-size: 13px; color: var(--mute); }
.h-trust-stat { font-size: 13.5px; color: var(--ink-2); }
.h-trust-stat b { font-family: 'Bricolage Grotesque', sans-serif; color: var(--ink); font-weight: 600; }
.h-trust-sep { width: 1px; height: 20px; background: var(--line-2); }
@media(max-width:680px) { .h-trust-sep { display: none; } .h-trust { gap: 12px 18px; } }

/* ── member journey ───────────────────────────────── */
.h-journey { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; align-items: stretch; gap: 0; }
.h-jstep { background: var(--panel); border: 1px solid var(--line); border-radius: 18px; padding: 30px 26px; transition: border-color .2s ease, transform .2s ease; }
.h-jstep:hover { border-color: var(--green); transform: translateY(-4px); }
.h-jstep-ic { width: 46px; height: 46px; border-radius: 12px; display: grid; place-items: center; background: var(--lime-soft); color: var(--green); margin-bottom: 18px; }
.h-jstep-ic svg { width: 23px; height: 23px; }
.h-jstep h3 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; font-size: 20px; margin: 0 0 8px; letter-spacing: -.02em; color: var(--ink); }
.h-jstep p { margin: 0; font-size: 14px; color: var(--ink-2); line-height: 1.5; }
.h-jline { align-self: center; width: 48px; height: 2px; background: repeating-linear-gradient(90deg, var(--line-2) 0 6px, transparent 6px 12px); }
/* mobile: vertical timeline with step counter and connector line */
@media(max-width:840px) {
  .h-journey {
    grid-template-columns: 1fr;
    gap: 0;
    padding-left: 20px;
    position: relative;
  }
  /* vertical spine */
  .h-journey::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 23px;
    bottom: 23px;
    width: 2px;
    background: linear-gradient(180deg, var(--green) 0%, var(--lime) 100%);
    opacity: .35;
    border-radius: 2px;
  }
  .h-jline { display: none; }
