---
import Layout from '../layouts/Layout.astro';
import { createPageMeta, PAGE_META } from '../utils/meta';

const metaData = createPageMeta('/logo', PAGE_META.home);
---

<Layout {...metaData} showHeader={false}>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@500;600;700;800&family=Manrope:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
  />

  <div class="logo-page">
    <header class="lp-head">
      <a href="/" class="lp-back">← volver al sitio</a>
      <h1>logo · exploración</h1>
      <p>Tres direcciones para evaluar. Mismo wordmark, distintas decisiones cromáticas.</p>
    </header>

    <!-- direction 01 -->
    <section class="lp-direction">
      <div class="lp-meta">
        <span class="lp-num">01</span>
        <h2><span class="dim">mas</span><span class="hl">socios</span></h2>
        <p class="lp-tag">muted + magenta</p>
        <p class="lp-rationale">
          <strong>Recomendado.</strong> "mas" recede como modificador, "socios" pop&shy;ea como el sustantivo
          que importa — más socios = más plata. Magenta = color de acción del sitio,
          el ojo lo encuentra naturalmente.
        </p>
      </div>

      <div class="lp-mocks">
        <!-- standalone large -->
        <div class="mock-card">
          <span class="mock-label">standalone · 64px</span>
          <div class="mock-stage">
            <div class="logo-d1">
              <span class="mark">M</span>
              <span class="word">
                <span class="dim">mas</span><span class="hl">socios</span>
              </span>
            </div>
          </div>
        </div>

        <!-- navbar context -->
        <div class="mock-card">
          <span class="mock-label">navbar · contexto real</span>
          <nav class="mock-nav">
            <a href="#" class="logo-d1 nav">
              <span class="mark">M</span>
              <span class="word">
                <span class="dim">mas</span><span class="hl">socios</span>
              </span>
            </a>
            <div class="mock-nav-links">
              <span>Problema</span><span>Solución</span><span>Precios</span>
              <span class="mock-cta">Probar gratis ↗</span>
            </div>
          </nav>
        </div>

        <!-- inverse / dark -->
        <div class="mock-card dark">
          <span class="mock-label">sobre fondo oscuro</span>
          <div class="mock-stage dark">
            <div class="logo-d1 inverse">
              <span class="mark">M</span>
              <span class="word">
                <span class="dim">mas</span><span class="hl">socios</span>
              </span>
            </div>
          </div>
        </div>

        <!-- on yellow -->
        <div class="mock-card yellow">
          <span class="mock-label">sobre amarillo de marca</span>
          <div class="mock-stage yellow">
            <div class="logo-d1">
              <span class="mark dark">M</span>
              <span class="word">
                <span class="dim">mas</span><span class="hl">socios</span>
              </span>
            </div>
          </div>
        </div>

        <!-- favicon -->
        <div class="mock-card">
          <span class="mock-label">favicon · 32px</span>
          <div class="mock-stage tight">
            <div class="favi favi-d1">
              <span>M</span>
            </div>
            <div class="favi favi-d1 small">
              <span>M</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- direction 02 -->
    <section class="lp-direction">
      <div class="lp-meta">
        <span class="lp-num">02</span>
        <h2>mas<span class="dot">·</span>socios</h2>
        <p class="lp-tag">monocromo + acento puntual</p>
        <p class="lp-rationale">
          Más sobrio. Un único color para el wordmark, el magenta vive solo en
          un signo de puntuación entre las palabras. Envejece mejor, se imprime mejor,
          se lee como una sola palabra cuando el contexto lo pide.
        </p>
      </div>

      <div class="lp-mocks">
        <div class="mock-card">
          <span class="mock-label">standalone · 64px</span>
          <div class="mock-stage">
            <div class="logo-d2">
              <span class="mark">M</span>
              <span class="word">mas<span class="dot">·</span>socios</span>
            </div>
          </div>
        </div>

        <div class="mock-card">
          <span class="mock-label">navbar · contexto real</span>
          <nav class="mock-nav">
            <a href="#" class="logo-d2 nav">
              <span class="mark">M</span>
              <span class="word">mas<span class="dot">·</span>socios</span>
            </a>
            <div class="mock-nav-links">
              <span>Problema</span><span>Solución</span><span>Precios</span>
              <span class="mock-cta">Probar gratis ↗</span>
            </div>
          </nav>
        </div>

        <div class="mock-card dark">
          <span class="mock-label">sobre fondo oscuro</span>
          <div class="mock-stage dark">
            <div class="logo-d2 inverse">
              <span class="mark">M</span>
              <span class="word">mas<span class="dot">·</span>socios</span>
            </div>
          </div>
        </div>

        <div class="mock-card yellow">
          <span class="mock-label">sobre amarillo de marca</span>
          <div class="mock-stage yellow">
            <div class="logo-d2">
              <span class="mark dark">M</span>
              <span class="word">mas<span class="dot dark">·</span>socios</span>
            </div>
          </div>
        </div>

        <div class="mock-card">
          <span class="mock-label">variante · plus signo</span>
          <div class="mock-stage">
            <div class="logo-d2 plus">
              <span class="mark">M</span>
              <span class="word">mas<span class="plus">+</span>socios</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- direction 03 -->
    <section class="lp-direction">
      <div class="lp-meta">
        <span class="lp-num">03</span>
        <h2><span class="hl">mas</span><span class="ink">socios</span></h2>
        <p class="lp-tag">magenta + ink (invertido)</p>
        <p class="lp-rationale">
          El acento va en la <em>acción</em>: "MÁS". La idea grita "más, más, más socios".
          Más agresivo, más latino, más vendedor. Funciona muy bien en gráfica
          de Instagram pero puede chocar con el texto del sitio.
        </p>
      </div>

      <div class="lp-mocks">
        <div class="mock-card">
          <span class="mock-label">standalone · 64px</span>
          <div class="mock-stage">
            <div class="logo-d3">
              <span class="mark">M</span>
              <span class="word">
                <span class="hl">mas</span><span class="ink">socios</span>
              </span>
            </div>
          </div>
        </div>

        <div class="mock-card">
          <span class="mock-label">navbar · contexto real</span>
          <nav class="mock-nav">
            <a href="#" class="logo-d3 nav">
              <span class="mark">M</span>
              <span class="word">
                <span class="hl">mas</span><span class="ink">socios</span>
              </span>
            </a>
            <div class="mock-nav-links">
              <span>Problema</span><span>Solución</span><span>Precios</span>
              <span class="mock-cta">Probar gratis ↗</span>
            </div>
          </nav>
        </div>

        <div class="mock-card dark">
          <span class="mock-label">sobre fondo oscuro</span>
          <div class="mock-stage dark">
            <div class="logo-d3 inverse">
              <span class="mark">M</span>
              <span class="word">
                <span class="hl">mas</span><span class="ink">socios</span>
              </span>
            </div>
          </div>
        </div>

        <div class="mock-card yellow">
          <span class="mock-label">sobre amarillo de marca</span>
          <div class="mock-stage yellow">
            <div class="logo-d3">
              <span class="mark dark">M</span>
              <span class="word">
                <span class="hl">mas</span><span class="ink">socios</span>
              </span>
            </div>
          </div>
        </div>

        <div class="mock-card">
          <span class="mock-label">tagline lockup</span>
          <div class="mock-stage stack">
            <div class="logo-d3">
              <span class="mark">M</span>
              <span class="word">
                <span class="hl">mas</span><span class="ink">socios</span>
              </span>
            </div>
            <span class="logo-tag">whatsapp que vende, por vos</span>
          </div>
        </div>
      </div>
    </section>

    <!-- final comparison: with mark vs wordmark-only -->
    <section class="lp-compare">
      <div class="cmp-head">
        <span class="lp-num">04</span>
        <h2><span class="ink">con</span> <span class="hl">vs</span> <span class="ink">sin</span> bloque M</h2>
        <p class="lp-tag">decisión final · ¿el mark suma o resta?</p>
        <p class="lp-rationale" style="max-width:680px">
          Tomamos la dirección 01 (la recomendada: <span class="dim">mas</span><span class="hl">socios</span>) y la mostramos en cuatro contextos reales — navbar, hero, footer, favicon — con y sin el bloque <strong>M</strong> al lado del wordmark. La idea es ver dónde el bloque ayuda y dónde se siente redundante.
        </p>
      </div>

      <!-- navbar -->
      <div class="cmp-row">
        <span class="cmp-label">navbar</span>
        <div class="cmp-pair">
          <div class="cmp-card">
            <span class="cmp-tag">CON bloque M</span>
            <nav class="mock-nav">
              <a href="#" class="logo-d1 nav">
                <span class="mark">M</span>
                <span class="word"><span class="dim">mas</span><span class="hl">socios</span></span>
              </a>
              <div class="mock-nav-links">
                <span>Problema</span><span>Solución</span><span>Precios</span>
                <span class="mock-cta">Probar gratis ↗</span>
              </div>
            </nav>
          </div>
          <div class="cmp-card pick">
            <span class="cmp-tag pick">SIN bloque · wordmark only</span>
            <nav class="mock-nav">
              <a href="#" class="logo-d1 nav nomark">
                <span class="word"><span class="dim">mas</span><span class="hl">socios</span></span>
              </a>
              <div class="mock-nav-links">
                <span>Problema</span><span>Solución</span><span>Precios</span>
                <span class="mock-cta">Probar gratis ↗</span>
              </div>
            </nav>
          </div>
        </div>
      </div>

      <!-- hero -->
      <div class="cmp-row">
        <span class="cmp-label">hero · pantalla grande</span>
        <div class="cmp-pair">
          <div class="cmp-card">
            <span class="cmp-tag">CON bloque M</span>
            <div class="hero-stage">
              <div class="logo-d1 hero-size">
                <span class="mark">M</span>
                <span class="word"><span class="dim">mas</span><span class="hl">socios</span></span>
              </div>
            </div>
          </div>
          <div class="cmp-card pick">
            <span class="cmp-tag pick">SIN bloque</span>
            <div class="hero-stage">
              <div class="logo-d1 nomark hero-size">
                <span class="word"><span class="dim">mas</span><span class="hl">socios</span></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- footer -->
      <div class="cmp-row">
        <span class="cmp-label">footer · sobre dark</span>
        <div class="cmp-pair">
          <div class="cmp-card dark">
            <span class="cmp-tag dark">CON bloque M</span>
            <div class="footer-stage">
              <a href="#" class="logo-d1 inverse foot-size">
                <span class="mark">M</span>
                <span class="word"><span class="dim">mas</span><span class="hl">socios</span></span>
              </a>
              <div class="foot-mock-links">
                <span>Producto</span><span>Precios</span><span>Contacto</span>
                <span>Términos</span><span>Privacidad</span>
              </div>
            </div>
          </div>
          <div class="cmp-card dark pick">
            <span class="cmp-tag dark pick">SIN bloque</span>
            <div class="footer-stage">
              <a href="#" class="logo-d1 inverse nomark foot-size">
                <span class="word"><span class="dim">mas</span><span class="hl">socios</span></span>
              </a>
              <div class="foot-mock-links">
                <span>Producto</span><span>Precios</span><span>Contacto</span>
                <span>Términos</span><span>Privacidad</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- favicon strategy -->
      <div class="cmp-row">
        <span class="cmp-label">favicon · pestaña del navegador</span>
        <div class="cmp-pair single">
          <div class="cmp-card pick">
            <span class="cmp-tag pick">FAVICON = solo el bloque M</span>
            <div class="favi-strategy">
              <div class="favi-stack">
                <div class="favi favi-d1"><span>M</span></div>
                <span class="favi-size">192px</span>
              </div>
              <div class="favi-stack">
                <div class="favi favi-d1 medium"><span>M</span></div>
                <span class="favi-size">64px</span>
              </div>
              <div class="favi-stack">
                <div class="favi favi-d1 small"><span>M</span></div>
                <span class="favi-size">32px</span>
              </div>
              <div class="favi-stack">
                <div class="favi favi-d1 tiny"><span>M</span></div>
                <span class="favi-size">16px</span>
              </div>
              <div class="favi-explain">
                <p><strong>El bloque vive solo acá.</strong> A 16/32px el wordmark sería ilegible — la M rotada con shadow se lee instantáneamente.</p>
                <p class="favi-tab"><span class="tab-favi"><span>M</span></span><span class="tab-title">massocios — whatsapp que vende</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- favicon options -->
      <div class="cmp-row" style="margin-top: 48px">
        <span class="cmp-label">favicon · cuatro direcciones a evaluar</span>
        <div class="favopt-grid">

          <!-- option A: lowercase m -->
          <div class="favopt">
            <div class="favopt-tag">A · `m` minúscula</div>
            <div class="favopt-stage">
              <div class="favopt-stack">
                <div class="favm size-192"><span>m</span></div>
                <span class="favopt-size">192</span>
              </div>
              <div class="favopt-stack">
                <div class="favm size-64"><span>m</span></div>
                <span class="favopt-size">64</span>
              </div>
              <div class="favopt-stack">
                <div class="favm size-32"><span>m</span></div>
                <span class="favopt-size">32</span>
              </div>
              <div class="favopt-stack">
                <div class="favm size-16"><span>m</span></div>
                <span class="favopt-size">16</span>
              </div>
            </div>
            <div class="favopt-tab">
              <span class="tab-favi-real favm-tab"><span>m</span></span>
              <span class="tab-title">massocios — whatsapp que vende</span>
            </div>
            <p class="favopt-note">Consistente con el lowercase del wordmark. Pero sigue siendo solo una letra.</p>
          </div>

          <!-- option B: plus sign -->
          <div class="favopt pick">
            <div class="favopt-tag pick">B · `+` signo más <span class="rec">recomendado</span></div>
            <div class="favopt-stage">
              <div class="favopt-stack">
                <div class="favplus size-192"><span>+</span></div>
                <span class="favopt-size">192</span>
              </div>
              <div class="favopt-stack">
                <div class="favplus size-64"><span>+</span></div>
                <span class="favopt-size">64</span>
              </div>
              <div class="favopt-stack">
                <div class="favplus size-32"><span>+</span></div>
                <span class="favopt-size">32</span>
              </div>
              <div class="favopt-stack">
                <div class="favplus size-16"><span>+</span></div>
                <span class="favopt-size">16</span>
              </div>
            </div>
            <div class="favopt-tab">
              <span class="tab-favi-real favplus-tab"><span>+</span></span>
              <span class="tab-title">massocios — whatsapp que vende</span>
            </div>
            <p class="favopt-note">Símbolo, no letra. Es la promesa: <strong>más</strong> socios. Ownable, escalable, funciona en gráfica como multiplicador (+120 gyms).</p>
          </div>

          <!-- option C: bubble -->
          <div class="favopt">
            <div class="favopt-tag">C · burbuja de chat</div>
            <div class="favopt-stage">
              <div class="favopt-stack">
                <div class="favbub size-192">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z"/>
                  </svg>
                </div>
                <span class="favopt-size">192</span>
              </div>
              <div class="favopt-stack">
                <div class="favbub size-64">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z"/>
                  </svg>
                </div>
                <span class="favopt-size">64</span>
              </div>
              <div class="favopt-stack">
                <div class="favbub size-32">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z"/>
                  </svg>
                </div>
                <span class="favopt-size">32</span>
              </div>
              <div class="favopt-stack">
                <div class="favbub size-16">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z"/>
                  </svg>
                </div>
                <span class="favopt-size">16</span>
              </div>
            </div>
            <div class="favopt-tab">
              <span class="tab-favi-real favbub-tab">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z"/>
                </svg>
              </span>
              <span class="tab-title">massocios — whatsapp que vende</span>
            </div>
            <p class="favopt-note">Categoría: chat. Riesgo: se confunde con WhatsApp/iMessage en una grilla de pestañas. Genérico.</p>
          </div>

          <!-- option D: bubble + plus -->
          <div class="favopt">
            <div class="favopt-tag">D · burbuja con `+` adentro</div>
            <div class="favopt-stage">
              <div class="favopt-stack">
                <div class="favbubplus size-192">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z" fill="currentColor"/>
                    <path d="M12 7v8M8 11h8" stroke="var(--yellow)" stroke-width="2.4" stroke-linecap="round"/>
                  </svg>
                </div>
                <span class="favopt-size">192</span>
              </div>
              <div class="favopt-stack">
                <div class="favbubplus size-64">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z" fill="currentColor"/>
                    <path d="M12 7v8M8 11h8" stroke="var(--yellow)" stroke-width="2.6" stroke-linecap="round"/>
                  </svg>
                </div>
                <span class="favopt-size">64</span>
              </div>
              <div class="favopt-stack">
                <div class="favbubplus size-32">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z" fill="currentColor"/>
                    <path d="M12 7v8M8 11h8" stroke="var(--yellow)" stroke-width="3" stroke-linecap="round"/>
                  </svg>
                </div>
                <span class="favopt-size">32</span>
              </div>
              <div class="favopt-stack">
                <div class="favbubplus size-16">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z" fill="currentColor"/>
                    <path d="M12 7v8M8 11h8" stroke="var(--yellow)" stroke-width="4" stroke-linecap="round"/>
                  </svg>
                </div>
                <span class="favopt-size">16</span>
              </div>
            </div>
            <div class="favopt-tab">
              <span class="tab-favi-real favbubplus-tab">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 3h14a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z" fill="currentColor"/>
                  <path d="M12 7v8M8 11h8" stroke="var(--yellow)" stroke-width="4" stroke-linecap="round"/>
                </svg>
              </span>
              <span class="tab-title">massocios — whatsapp que vende</span>
            </div>
            <p class="favopt-note">"Más conversaciones, más socios" en un símbolo. Específico al producto. Riesgo: a 16px el `+` adentro casi desaparece — hay que confiar en la silueta.</p>
          </div>

        </div>
      </div>

      <!-- verdict -->
      <div class="cmp-verdict">
        <h3>Recomendación</h3>
        <ul>
          <li><strong>Wordmark only</strong> en navbar, footer, hero, gráficas, redes sociales horizontales — donde el wordmark es legible.</li>
          <li>Para el favicon, mi pick es <strong>opción B (`+`)</strong>: símbolo, no letra. Captura la promesa de marca (<em>más</em> socios) sin redundancia con el wordmark, y escala perfecto a 16px.</li>
          <li>Resultado: <strong>menos redundancia, más confianza.</strong> Como hace WhatsApp, Stripe, Linear, Notion.</li>
        </ul>
      </div>
    </section>

    <!-- direction 05: +socios rebrand -->
    <section class="lp-rebrand">
      <div class="rb-head">
        <span class="lp-num">05</span>
        <h2 class="rb-title">¿Y si el wordmark fuera <span class="rb-pop">+socios</span>?</h2>
        <p class="lp-tag">rebrand · el `+` carga toda la marca</p>
        <p class="lp-rationale" style="max-width:680px">
