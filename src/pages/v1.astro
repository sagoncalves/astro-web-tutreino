---
import Layout from '../layouts/Layout.astro';
import { createPageMeta, PAGE_META, SITE_CONFIG } from '../utils/meta';

const metaData = createPageMeta('/v1', PAGE_META.home);
const registroUrl = SITE_CONFIG.appRegistrationUrl;
---

<Layout {...metaData} showHeader={false}>
  <link
    slot="head"
    rel="preconnect"
    href="https://fonts.googleapis.com"
  />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..700,0..100&family=Inter+Tight:wght@400;500;600;700&display=swap"
  />

  <div class="v1-root">
    <h2 class="sr-only">MasSocios — automatización WhatsApp para gimnasios</h2>

    <div class="grain" aria-hidden="true"></div>

    <nav class="v1-nav" aria-label="Principal">
      <a href="/" class="v1-logo">
        <span class="dot"></span>
        mas<em>socios</em>
      </a>
      <div class="v1-nav-links">
        <a href="#funciones">Funciones</a>
        <a href="#como">Cómo funciona</a>
        <a href="#precios">Precios</a>
        <a class="v1-nav-cta" href={registroUrl} target="_blank" rel="noopener noreferrer">
          Probar gratis
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </nav>

    <header class="v1-hero">
      <div class="v1-hero-meta">
        <span class="v1-pill">
          <span class="pulse"></span>
          Online · responde en &lt; 1 min
        </span>
        <span class="v1-since">Hecho en Uruguay · 2026</span>
      </div>

      <h1 class="v1-h1">
        El asistente que <em>convierte</em> consultas
        <br />de WhatsApp en <span class="underline-coral">socios pagos</span>.
      </h1>

      <p class="v1-lead">
        MasSocios responde, agenda y hace seguimiento por vos.
        Cada lead recibe la atención que merece — sin que tu equipo levante el celular.
      </p>

      <div class="v1-cta-row">
        <a class="v1-btn-primary" href={registroUrl} target="_blank" rel="noopener noreferrer">
          Empezá 14 días gratis
        </a>
        <a class="v1-btn-ghost" href="#demo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M10 8l6 4-6 4V8z" fill="currentColor" stroke="none" />
          </svg>
          Ver cómo conversa
        </a>
      </div>

      <div class="v1-trust">
        <div class="avatars">
          <span class="av av-1">JM</span>
          <span class="av av-2">LR</span>
          <span class="av av-3">PC</span>
          <span class="av av-4">MS</span>
        </div>
        <p>
          <strong>+120 gimnasios</strong> ya automatizaron sus consultas.
          <br />Sin tarjeta. Sin instalaciones. Sin compromiso.
        </p>
      </div>

      <aside class="v1-hero-card" aria-label="Vista previa de conversación">
        <div class="card-head">
          <div class="head-left">
            <div class="head-av">M</div>
            <div>
              <div class="head-name">Asistente · Gym Pacífico</div>
              <div class="head-status"><span class="pulse small"></span> escribiendo…</div>
            </div>
          </div>
          <div class="head-right">
            <span class="kbd">whatsapp</span>
          </div>
        </div>
        <div class="card-body">
          <div class="bbl bbl-them">
            Hola! Vi que pasaste por la web. ¿Querés que te cuente sobre los planes? 💪
          </div>
          <div class="bbl bbl-me">
            Sí, qué planes tienen y horarios?
          </div>
          <div class="bbl bbl-them long">
            <strong>Planes:</strong><br />
            · Mensual UYU 1.800<br />
            · Trimestral UYU 4.800 <span class="tag">−10%</span><br /><br />
            <strong>Horarios:</strong> Lun a Vie 6 a 23, Sáb 8 a 14.<br /><br />
            ¿Te coordino una clase de prueba sin costo?
          </div>
          <div class="bbl bbl-me">
            Dale, mañana 19hs.
          </div>
          <div class="bbl bbl-them confirm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Reservado · te paso la dirección y te recuerdo 1h antes.
          </div>
        </div>
      </aside>
    </header>

    <section class="v1-stats">
      <div class="stat">
        <div class="stat-num">68<span>%</span></div>
        <div class="stat-lbl">leads que terminan visitando el gym</div>
      </div>
      <div class="stat">
        <div class="stat-num">3,2<span>hs</span></div>
        <div class="stat-lbl">ahorradas por día en consultas</div>
      </div>
      <div class="stat">
        <div class="stat-num">98<span>%</span></div>
        <div class="stat-lbl">consultas resueltas sin humano</div>
      </div>
      <div class="stat">
        <div class="stat-num">24<span>/7</span></div>
        <div class="stat-lbl">disponible — incluso a las 11pm</div>
      </div>
    </section>

    <section class="v1-section v1-pain" id="problema">
      <div class="v1-section-head">
        <span class="v1-eyebrow">El problema</span>
        <h2 class="v1-h2">Cada consulta sin respuesta <em>es un socio que no llega</em>.</h2>
      </div>
      <div class="v1-pain-grid">
        <article class="pain">
          <div class="pain-num">01</div>
          <h3>Mensajes que se pierden</h3>
          <p>Consultas a las 11pm que nadie ve hasta el otro día. Para entonces ya buscaron otro gym.</p>
        </article>
        <article class="pain">
          <div class="pain-num">02</div>
          <h3>Las mismas 5 preguntas</h3>
          <p>Precios, horarios, ubicación. Tu staff repite lo mismo 30 veces por día.</p>
        </article>
        <article class="pain">
          <div class="pain-num">03</div>
          <h3>Socios que se van en silencio</h3>
          <p>Membresías que vencen sin aviso porque nadie tuvo tiempo de hacer seguimiento.</p>
        </article>
        <article class="pain">
          <div class="pain-num">04</div>
          <h3>Clases con lugares vacíos</h3>
          <p>Reservas no confirmadas, recordatorios que no se mandan, ingresos que se pierden.</p>
        </article>
      </div>
    </section>

    <section class="v1-section v1-how" id="como">
      <div class="v1-section-head">
        <span class="v1-eyebrow">Cómo funciona</span>
        <h2 class="v1-h2">Listo en una tarde. <em>Para siempre.</em></h2>
      </div>
      <ol class="v1-steps">
        <li>
          <span class="step-tag">Paso 1</span>
          <h3>Conectás tu WhatsApp Business</h3>
          <p>5 minutos. Sin cambiar tu número. Sin perder tus chats actuales.</p>
        </li>
        <li>
          <span class="step-tag">Paso 2</span>
          <h3>Le contás sobre tu gym</h3>
          <p>Horarios, planes, clases, profesores. El asistente aprende todo y responde como tu equipo.</p>
        </li>
        <li>
          <span class="step-tag">Paso 3</span>
          <h3>Empieza a convertir solo</h3>
          <p>Responde 24/7, agenda clases de prueba, hace seguimiento y te avisa solo cuando hace falta.</p>
        </li>
      </ol>
    </section>

    <section class="v1-section v1-features" id="funciones">
      <div class="v1-section-head">
        <span class="v1-eyebrow">Qué hace por vos</span>
        <h2 class="v1-h2">Un asistente que <em>realmente</em> trabaja.</h2>
      </div>
      <div class="v1-feat-grid">
        <article class="feat feat-large">
          <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <h3>Conversaciones que convierten</h3>
          <p>El asistente identifica leads calientes, agenda clases de prueba y los empuja a inscribirse — con el tono de tu marca.</p>
          <ul class="feat-list">
            <li>Responde precios, horarios y planes al instante</li>
            <li>Agenda clases de prueba en tu calendario</li>
            <li>Detecta cuándo escalar al humano</li>
          </ul>
        </article>

        <article class="feat">
          <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 6v6l4 2" stroke-linecap="round" />
          </svg>
          <h3>Follow-ups automáticos</h3>
          <p>Recordatorios de pago, vencimientos, cumpleaños y reactivación de socios inactivos.</p>
        </article>

        <article class="feat">
          <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <path d="M16 2v4M8 2v4M3 10h18" stroke-linecap="round" />
          </svg>
          <h3>Reservas por chat</h3>
          <p>El socio reserva su clase desde WhatsApp. Sin apps extra, sin fricción.</p>
        </article>

        <article class="feat">
          <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M3 3v18h18" stroke-linecap="round" />
            <path d="M7 14l4-4 4 4 5-5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <h3>Métricas reales</h3>
          <p>Cuántos leads convertiste, cuánto tiempo ahorraste, qué consultas se repiten más.</p>
        </article>

        <article class="feat">
          <svg class="feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke-linecap="round" />
            <circle cx="9" cy="7" r="4" />
            <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke-linecap="round" />
          </svg>
          <h3>Bandeja unificada</h3>
          <p>Todos los chats con la ficha del socio al lado. Tu equipo nunca pregunta dos veces lo mismo.</p>
        </article>
      </div>
    </section>

    <section class="v1-section v1-demo" id="demo">
      <div class="v1-section-head">
        <span class="v1-eyebrow">En acción</span>
        <h2 class="v1-h2">El follow-up que tu staff <em>nunca</em> tiene tiempo de hacer.</h2>
      </div>

      <div class="v1-demo-wrap">
        <div class="demo-side">
          <div class="demo-tag">3 días después de no ir al gym</div>
          <p class="demo-copy">El asistente reactiva socios automáticamente, con un mensaje personalizado según su historial. Recupera ~1 de cada 4.</p>
          <div class="demo-meta">
            <div><strong>Trigger</strong><span>3 días sin check-in</span></div>
            <div><strong>Tono</strong><span>Cálido, motivador</span></div>
            <div><strong>Resultado</strong><span>27% retorno</span></div>
          </div>
        </div>
        <div class="demo-chat">
          <div class="demo-bbl them">
            Hola Marcos! Te extrañamos esta semana 💪
            ¿Todo bien? Si necesitás cambiar el horario, te ayudo a reservar otra clase.
          </div>
          <div class="demo-bbl me">
            Ando complicado con laburo, gracias!
          </div>
          <div class="demo-bbl them">
            Sin drama. Te dejo agendada una clase de funcional para el sábado 10am — si no podés, me avisás y la cambio.
          </div>
          <div class="demo-bbl me thumb">👍</div>
        </div>
      </div>
    </section>

    <section class="v1-section v1-pricing" id="precios">
      <div class="v1-section-head">
        <span class="v1-eyebrow">Precios honestos</span>
        <h2 class="v1-h2">Pagás <em>menos</em> que un día de staff.</h2>
        <p class="v1-section-sub">Sin letra chica. Sin permanencia. Cancelás cuando quieras.</p>
      </div>

      <div class="v1-price-grid">
        <article class="price">
          <header>
            <h3>Starter</h3>
            <p>Para gyms que recién empiezan a automatizar.</p>
          </header>
          <div class="price-amount"><span class="cur">UYU</span>1.800<span class="per">/mes</span></div>
          <ul>
            <li>Bandeja unificada de WhatsApp</li>
            <li>Recordatorios automáticos</li>
            <li>Hasta 200 socios</li>
            <li>Soporte por WhatsApp</li>
          </ul>
          <a class="price-cta" href={registroUrl} target="_blank" rel="noopener noreferrer">Empezar</a>
        </article>

        <article class="price featured">
          <span class="price-badge">Recomendado</span>
          <header>
            <h3>Pro</h3>
            <p>Con asistente IA. Atiende sin que vos hagas nada.</p>
          </header>
          <div class="price-amount"><span class="cur">UYU</span>3.200<span class="per">/mes</span></div>
          <ul>
            <li>Todo lo de Starter</li>
            <li>Asistente IA conversacional 24/7</li>
            <li>Reservas y follow-ups automáticos</li>
            <li>Sin límite de socios</li>
            <li>Reportes mensuales de conversión</li>
          </ul>
          <a class="price-cta featured" href={registroUrl} target="_blank" rel="noopener noreferrer">Probar 14 días gratis</a>
        </article>
      </div>
    </section>

    <section class="v1-section v1-faq">
      <div class="v1-section-head">
        <span class="v1-eyebrow">Antes de empezar</span>
        <h2 class="v1-h2">Lo que todos preguntan.</h2>
      </div>
      <div class="v1-faq-list">
        <details>
          <summary>¿Necesito saber programar?</summary>
          <p>No. Si sabés mandar un mensaje de WhatsApp, podés usar MasSocios. La configuración es 100% visual y te acompañamos en el setup.</p>
        </details>
        <details>
          <summary>¿Funciona con mi número actual?</summary>
          <p>Sí, siempre que sea WhatsApp Business. Si todavía no lo tenés, te ayudamos a migrar sin perder tus chats.</p>
        </details>
        <details>
          <summary>¿Y si el bot no sabe responder?</summary>
          <p>Te avisa al instante y te pasa la conversación. Nunca dejamos a un socio sin respuesta — el humano siempre está un click atrás.</p>
        </details>
        <details>
          <summary>¿Puedo probarlo antes de pagar?</summary>
          <p>14 días gratis, sin tarjeta. Si no te convence, no pagás nada y conservás tus chats.</p>
        </details>
        <details>
          <summary>¿Qué tipo de gym puede usarlo?</summary>
          <p>Funcional, musculación, crossfit, pilates, yoga, artes marciales. Si tenés socios y WhatsApp, te sirve.</p>
        </details>
      </div>
    </section>

    <section class="v1-cta">
      <div class="cta-inner">
        <h2>Empezá hoy. <em>Cobrá mañana.</em></h2>
        <p>14 días gratis. Sin tarjeta. Sin compromiso. Setup en una tarde.</p>
        <div class="cta-row">
          <a class="v1-btn-primary big" href={registroUrl} target="_blank" rel="noopener noreferrer">Probar MasSocios gratis</a>
          <span class="cta-note">o <a href="mailto:hola@massocios.com">escribinos</a> y agendamos una demo</span>
        </div>
      </div>
    </section>

    <footer class="v1-foot">
      <div>
        <a href="/" class="v1-logo small"><span class="dot"></span>mas<em>socios</em></a>
        <p>El asistente de WhatsApp para gimnasios.</p>
      </div>
      <div class="v1-foot-cols">
        <div>
          <h4>Producto</h4>
          <a href="#funciones">Funciones</a>
          <a href="#precios">Precios</a>
          <a href="#demo">Demo</a>
        </div>
        <div>
          <h4>Empresa</h4>
          <a href="mailto:hola@massocios.com">Contacto</a>
          <a href="/">Sobre nosotros</a>
        </div>
        <div>
          <h4>Legal</h4>
          <a href="/">Términos</a>
          <a href="/">Privacidad</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style is:global>
  .v1-root {
    --bg: #f7f5f0;
    --bg-2: #efece4;
    --ink: #0b1410;
    --ink-2: #1c2a23;
    --mute: #6b7771;
    --line: #d9d3c4;
    --green: #00a884;
    --green-deep: #007a5e;
    --green-soft: #d6f0e6;
    --coral: #ff6b47;
    --coral-soft: #ffe7df;
    --paper: #fffdf8;

    background: var(--bg);
    color: var(--ink);
    font-family: 'Inter Tight', system-ui, sans-serif;
    font-feature-settings: 'ss01', 'cv11';
    line-height: 1.55;
    position: relative;
    overflow-x: hidden;
  }

  .v1-root .grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.06;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .v1-root .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  /* ───── nav ───── */
  .v1-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px clamp(20px, 5vw, 56px);
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--line) 60%, transparent);
  }
  .v1-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Fraunces', serif;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
  }
  .v1-logo em { font-style: italic; color: var(--green-deep); }
  .v1-logo .dot {
    width: 10px; height: 10px; border-radius: 999px;
    background: var(--green);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--green) 25%, transparent);
  }
  .v1-nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .v1-nav-links a {
    color: var(--ink-2);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.18s ease;
  }
  .v1-nav-links a:hover { color: var(--green-deep); }
  .v1-nav-cta {
    display: inline-flex !important;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    border-radius: 999px;
    background: var(--ink);
    color: var(--bg) !important;
    font-weight: 500;
    cursor: pointer;
    transition: transform 0.18s ease, background 0.18s ease;
  }
  .v1-nav-cta:hover { background: var(--green-deep); color: var(--bg) !important; }
  .v1-nav-cta svg { width: 14px; height: 14px; }

  @media (max-width: 720px) {
    .v1-nav-links a:not(.v1-nav-cta) { display: none; }
  }

  /* ───── hero ───── */
  .v1-hero {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(48px, 9vw, 110px) clamp(20px, 5vw, 56px) 60px;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 64px;
    align-items: start;
  }
  @media (max-width: 960px) {
    .v1-hero { grid-template-columns: 1fr; gap: 40px; }
  }

  .v1-hero-meta {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 8px;
  }
  .v1-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border-radius: 999px;
    background: var(--green-soft);
    color: var(--green-deep);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .v1-pill .pulse {
    width: 8px; height: 8px; border-radius: 999px;
    background: var(--green);
    position: relative;
  }
  .v1-pill .pulse::after {
    content: '';
    position: absolute; inset: -4px;
    border-radius: 999px;
    background: var(--green);
    opacity: 0.3;
    animation: v1pulse 1.6s ease-out infinite;
  }
  .pulse.small { width: 6px; height: 6px; }
  @keyframes v1pulse {
    0% { transform: scale(0.9); opacity: 0.45; }
    100% { transform: scale(2); opacity: 0; }
  }
  .v1-since {
    font-size: 13px;
    color: var(--mute);
    font-feature-settings: 'tnum';
  }

  .v1-h1 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(40px, 6.6vw, 92px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin: 0;
  }
  .v1-h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--green-deep);
  }
  .underline-coral {
    background-image: linear-gradient(180deg, transparent 62%, var(--coral-soft) 62%, var(--coral-soft) 92%, transparent 92%);
    padding: 0 6px;
  }

  .v1-lead {
    font-size: clamp(17px, 1.4vw, 20px);
    color: var(--ink-2);
    max-width: 540px;
    margin: 28px 0 36px;
    line-height: 1.55;
  }

  .v1-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 40px;
  }
  .v1-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 26px;
    border-radius: 999px;
    background: var(--ink);
    color: var(--paper);
    font-weight: 500;
    font-size: 15px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04), 0 12px 24px -12px rgba(0, 0, 0, 0.25);
  }
  .v1-btn-primary:hover { background: var(--green-deep); }
  .v1-btn-primary.big { padding: 20px 36px; font-size: 17px; }
  .v1-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 22px;
    border-radius: 999px;
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--line);
    font-weight: 500;
    font-size: 15px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.18s ease, border-color 0.18s ease;
  }
  .v1-btn-ghost svg { width: 18px; height: 18px; color: var(--coral); }
  .v1-btn-ghost:hover { background: var(--paper); border-color: var(--ink-2); }

  .v1-trust {
    display: flex;
    align-items: center;
    gap: 16px;
    color: var(--mute);
    font-size: 14px;
  }
  .v1-trust strong { color: var(--ink); font-weight: 600; }
  .avatars { display: flex; }
  .avatars .av {
    width: 36px; height: 36px;
    border-radius: 999px;
    background: var(--green-soft);
    color: var(--green-deep);
    font-size: 12px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--bg);
    margin-left: -8px;
    font-family: 'Inter Tight', sans-serif;
  }
  .avatars .av:first-child { margin-left: 0; }
  .avatars .av-2 { background: #ffe2cc; color: #b8431a; }
  .avatars .av-3 { background: #e6e2d5; color: #4a4231; }
  .avatars .av-4 { background: #d6e8f0; color: #1a4a5e; }

  /* hero card */
  .v1-hero-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: 18px;
    box-shadow: 0 1px 0 #fff inset, 0 30px 60px -30px rgba(11, 20, 16, 0.18), 0 8px 18px -10px rgba(11, 20, 16, 0.1);
    transform: rotate(-0.6deg);
    position: relative;
  }
  .v1-hero-card::before {
    content: '';
    position: absolute;
    inset: -10px -10px auto auto;
    width: 70px; height: 70px;
    background: var(--coral);
    border-radius: 999px;
    z-index: -1;
    opacity: 0.85;
    filter: blur(2px);
  }
  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 8px 14px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 14px;
  }
  .head-left { display: flex; align-items: center; gap: 12px; }
  .head-av {
    width: 38px; height: 38px;
    border-radius: 999px;
    background: var(--green);
    color: white;
    display: grid; place-items: center;
    font-weight: 600;
    font-family: 'Fraunces', serif;
  }
  .head-name { font-weight: 600; font-size: 14px; }
  .head-status { font-size: 12px; color: var(--mute); display: inline-flex; align-items: center; gap: 6px; }
  .kbd {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 12px;
    color: var(--mute);
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid var(--line);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bbl {
    max-width: 78%;
    padding: 10px 14px;
    border-radius: 18px;
    font-size: 14.5px;
    line-height: 1.45;
    animation: v1in 0.5s ease both;
  }
  .bbl-them {
    background: var(--green-soft);
    color: var(--ink);
    border-bottom-left-radius: 6px;
    align-self: flex-start;
  }
  .bbl-them.long .tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--coral-soft);
    color: var(--coral);
    font-size: 11px;
    font-weight: 600;
    margin-left: 4px;
  }
  .bbl-them.confirm {
    display: flex; align-items: center; gap: 8px;
    background: white;
    border: 1px solid var(--green-soft);
    color: var(--green-deep);
    font-weight: 500;
  }
  .bbl-them.confirm svg { width: 16px; height: 16px; flex-shrink: 0; }
  .bbl-me {
    background: var(--ink);
    color: var(--paper);
    border-bottom-right-radius: 6px;
    align-self: flex-end;
  }
  @keyframes v1in {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .bbl:nth-child(1) { animation-delay: 0.1s; }
  .bbl:nth-child(2) { animation-delay: 0.3s; }
  .bbl:nth-child(3) { animation-delay: 0.5s; }
  .bbl:nth-child(4) { animation-delay: 0.7s; }
  .bbl:nth-child(5) { animation-delay: 0.9s; }

  /* ───── stats ───── */
  .v1-stats {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: 40px clamp(20px, 5vw, 56px);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 720px) {
    .v1-stats { grid-template-columns: repeat(2, 1fr); }
  }
  .v1-stats .stat {
    padding: 28px 24px;
    border-right: 1px solid var(--line);
  }
  .v1-stats .stat:last-child { border-right: none; }
  @media (max-width: 720px) {
    .v1-stats .stat:nth-child(2) { border-right: none; }
    .v1-stats .stat:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
  }
  .stat-num {
    font-family: 'Fraunces', serif;
    font-size: clamp(38px, 4.5vw, 56px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .stat-num span {
    font-style: italic;
    color: var(--green-deep);
    font-size: 0.55em;
    margin-left: 4px;
  }
  .stat-lbl {
    margin-top: 10px;
    font-size: 13.5px;
    color: var(--mute);
    line-height: 1.4;
  }

  /* ───── sections shared ───── */
  .v1-section {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(70px, 10vw, 130px) clamp(20px, 5vw, 56px);
  }
  .v1-section-head {
    max-width: 760px;
    margin-bottom: 56px;
  }
  .v1-eyebrow {
    display: inline-block;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 14px;
    color: var(--coral);
    margin-bottom: 18px;
    letter-spacing: 0.02em;
  }
  .v1-eyebrow::before {
    content: '— ';
  }
  .v1-h2 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(34px, 4.4vw, 60px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0;
  }
  .v1-h2 em { font-style: italic; color: var(--green-deep); font-weight: 400; }
  .v1-section-sub {
    margin-top: 18px;
    color: var(--mute);
    font-size: 17px;
    max-width: 540px;
  }

  /* ───── pain ───── */
  .v1-pain-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
  }
  @media (max-width: 720px) { .v1-pain-grid { grid-template-columns: 1fr; } }
  .pain {
    background: var(--bg);
    padding: 36px 32px;
    transition: background 0.2s ease;
  }
  .pain:hover { background: var(--paper); }
  .pain-num {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 14px;
    color: var(--coral);
    margin-bottom: 12px;
  }
  .pain h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 24px;
    letter-spacing: -0.015em;
    margin: 0 0 8px;
  }
  .pain p { color: var(--mute); margin: 0; font-size: 15px; }

  /* ───── how ───── */
  .v1-steps {
    list-style: none;
    counter-reset: step;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 860px) { .v1-steps { grid-template-columns: 1fr; } }
  .v1-steps li {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 32px 28px;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .v1-steps li:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 50px -28px rgba(11, 20, 16, 0.18);
  }
  .step-tag {
    display: inline-block;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 13px;
    color: var(--coral);
    margin-bottom: 14px;
  }
  .v1-steps h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 22px;
    letter-spacing: -0.015em;
    margin: 0 0 8px;
  }
  .v1-steps p { color: var(--mute); margin: 0; font-size: 15px; }

  /* ───── features ───── */
  .v1-feat-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
  }
  .feat {
    grid-column: span 2;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 30px 28px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.2s ease;
  }
  .feat:hover {
    transform: translateY(-4px);
    border-color: var(--green);
    box-shadow: 0 22px 48px -28px rgba(0, 168, 132, 0.35);
  }
  .feat-large {
    grid-column: span 6;
    background: linear-gradient(135deg, var(--paper) 0%, var(--green-soft) 100%);
  }
  .feat-large .feat-list {
    margin-top: 18px;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
  }
  .feat-large .feat-list li {
    font-size: 14px;
    color: var(--ink-2);
    padding-left: 18px;
    position: relative;
  }
  .feat-large .feat-list li::before {
    content: '';
    position: absolute;
    left: 0; top: 8px;
    width: 6px; height: 6px;
    border-radius: 999px;
    background: var(--green);
  }
  .feat-icon {
    width: 28px; height: 28px;
    color: var(--green-deep);
    margin-bottom: 18px;
  }
  .feat h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 22px;
    letter-spacing: -0.015em;
    margin: 0 0 8px;
  }
  .feat p { color: var(--mute); margin: 0; font-size: 15px; line-height: 1.55; }
  @media (max-width: 960px) {
    .v1-feat-grid { grid-template-columns: repeat(2, 1fr); }
    .feat { grid-column: span 1; }
    .feat-large { grid-column: span 2; }
  }
  @media (max-width: 600px) {
    .v1-feat-grid { grid-template-columns: 1fr; }
    .feat-large { grid-column: span 1; }
  }

  /* ───── demo ───── */
  .v1-demo-wrap {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 48px;
    align-items: center;
    background: var(--ink);
    color: var(--paper);
    border-radius: 28px;
    padding: clamp(36px, 6vw, 72px);
    position: relative;
    overflow: hidden;
  }
  .v1-demo-wrap::before {
    content: '';
    position: absolute;
    width: 320px; height: 320px;
    border-radius: 999px;
    background: radial-gradient(circle, var(--coral) 0%, transparent 70%);
    opacity: 0.4;
    top: -100px; right: -120px;
  }
  @media (max-width: 860px) { .v1-demo-wrap { grid-template-columns: 1fr; gap: 32px; } }
  .demo-side { position: relative; z-index: 1; }
  .demo-tag {
    display: inline-block;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 14px;
    color: var(--coral);
    margin-bottom: 16px;
  }
  .demo-copy {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin: 0 0 32px;
  }
  .demo-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    border-top: 1px solid color-mix(in srgb, var(--paper) 20%, transparent);
    padding-top: 24px;
  }
  .demo-meta div { display: flex; flex-direction: column; gap: 4px; }
  .demo-meta strong { font-size: 12px; color: color-mix(in srgb, var(--paper) 60%, transparent); font-weight: 500; }
  .demo-meta span { font-family: 'Fraunces', serif; font-size: 18px; }

  .demo-chat {
    position: relative; z-index: 1;
    background: color-mix(in srgb, var(--paper) 8%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in srgb, var(--paper) 12%, transparent);
    border-radius: 22px;
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .demo-bbl {
    max-width: 80%;
    padding: 12px 16px;
    border-radius: 18px;
    font-size: 14.5px;
    line-height: 1.5;
  }
  .demo-bbl.them { background: color-mix(in srgb, var(--green) 90%, white); color: white; align-self: flex-start; border-bottom-left-radius: 6px; }
  .demo-bbl.me { background: var(--paper); color: var(--ink); align-self: flex-end; border-bottom-right-radius: 6px; }
  .demo-bbl.thumb { font-size: 28px; padding: 6px 12px; }

  /* ───── pricing ───── */
  .v1-price-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 920px;
    margin: 0 auto;
  }
  @media (max-width: 720px) { .v1-price-grid { grid-template-columns: 1fr; } }
  .price {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: relative;
    transition: transform 0.25s ease;
  }
  .price:hover { transform: translateY(-4px); }
  .price.featured {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .price-badge {
    position: absolute;
    top: -14px; left: 32px;
    background: var(--coral);
    color: white;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .price h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 26px;
    margin: 0 0 6px;
    letter-spacing: -0.02em;
  }
  .price header p { margin: 0; color: var(--mute); font-size: 14.5px; }
  .price.featured header p { color: color-mix(in srgb, var(--paper) 65%, transparent); }
  .price-amount {
    font-family: 'Fraunces', serif;
    font-size: 56px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .price-amount .cur {
    font-size: 14px;
    color: var(--mute);
    font-family: 'Inter Tight', sans-serif;
    font-weight: 500;
  }
  .price.featured .price-amount .cur { color: color-mix(in srgb, var(--paper) 60%, transparent); }
  .price-amount .per {
    font-size: 16px;
    color: var(--mute);
    font-family: 'Inter Tight', sans-serif;
    font-weight: 500;
  }
  .price.featured .price-amount .per { color: color-mix(in srgb, var(--paper) 60%, transparent); }
  .price ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .price li {
    font-size: 15px;
    padding-left: 28px;
    position: relative;
    color: var(--ink-2);
  }
  .price.featured li { color: color-mix(in srgb, var(--paper) 88%, transparent); }
  .price li::before {
    content: '';
    position: absolute;
    left: 0; top: 7px;
    width: 14px; height: 8px;
    border-left: 2px solid var(--green);
    border-bottom: 2px solid var(--green);
    transform: rotate(-45deg);
  }
  .price.featured li::before { border-color: var(--green); }
  .price-cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 22px;
    border-radius: 999px;
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
    text-decoration: none;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .price-cta:hover { background: var(--ink); color: var(--paper); }
  .price-cta.featured {
    background: var(--coral);
    color: white;
    border-color: var(--coral);
  }
  .price-cta.featured:hover { background: white; color: var(--ink); border-color: white; }

  /* ───── faq ───── */
  .v1-faq-list {
    max-width: 760px;
    border-top: 1px solid var(--line);
  }
  .v1-faq-list details {
    border-bottom: 1px solid var(--line);
    padding: 22px 0;
  }
  .v1-faq-list summary {
    cursor: pointer;
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 20px;
    letter-spacing: -0.01em;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .v1-faq-list summary::-webkit-details-marker { display: none; }
  .v1-faq-list summary::after {
    content: '+';
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 28px;
    color: var(--coral);
    transition: transform 0.2s ease;
  }
  .v1-faq-list details[open] summary::after { content: '–'; }
  .v1-faq-list p {
    margin: 14px 0 0;
    color: var(--mute);
    font-size: 15.5px;
    max-width: 600px;
  }

  /* ───── final CTA ───── */
  .v1-cta {
    position: relative;
    z-index: 2;
    margin: 0 clamp(20px, 5vw, 56px);
    margin-bottom: 40px;
  }
  .cta-inner {
    background: var(--ink);
    color: var(--paper);
    border-radius: 32px;
    padding: clamp(50px, 8vw, 110px) clamp(28px, 6vw, 80px);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-inner::before {
    content: '';
    position: absolute;
    width: 120%; height: 200%;
    top: -50%; left: -10%;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--green) 30%, transparent) 0%, transparent 50%);
    pointer-events: none;
  }
  .cta-inner h2 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(40px, 6vw, 78px);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 18px;
    position: relative;
  }
  .cta-inner h2 em { font-style: italic; color: var(--coral); }
  .cta-inner p {
    color: color-mix(in srgb, var(--paper) 70%, transparent);
    margin: 0 0 36px;
    font-size: 17px;
    position: relative;
  }
  .cta-row {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
  }
  .cta-row .v1-btn-primary {
    background: var(--coral);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--coral) 30%, transparent), 0 24px 60px -20px rgba(255, 107, 71, 0.6);
  }
  .cta-row .v1-btn-primary:hover { background: white; color: var(--ink); }
  .cta-note {
    font-size: 14px;
    color: color-mix(in srgb, var(--paper) 60%, transparent);
  }
  .cta-note a { color: var(--paper); text-decoration: underline; text-underline-offset: 4px; }

  /* ───── footer ───── */
  .v1-foot {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px clamp(20px, 5vw, 56px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    border-top: 1px solid var(--line);
    align-items: start;
  }
  @media (max-width: 720px) { .v1-foot { grid-template-columns: 1fr; } }
  .v1-foot p { color: var(--mute); margin: 12px 0 0; font-size: 14px; }
  .v1-logo.small { font-size: 18px; }
