---
import Layout from '../layouts/Layout.astro';
import { createPageMeta, PAGE_META, SITE_CONFIG } from '../utils/meta';

const metaData = createPageMeta('/v2', PAGE_META.home);
const registroUrl = SITE_CONFIG.appRegistrationUrl;
---

<Layout {...metaData} showHeader={false}>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;500;600;700&family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
  />

  <div class="v2-root">
    <h2 class="sr-only">MasSocios — el OS conversacional para gimnasios</h2>

    <div class="grid-bg" aria-hidden="true"></div>
    <div class="glow glow-1" aria-hidden="true"></div>
    <div class="glow glow-2" aria-hidden="true"></div>

    <nav class="v2-nav" aria-label="Principal">
      <a href="/" class="v2-logo">
        <svg viewBox="0 0 32 32" aria-hidden="true">
          <circle cx="16" cy="16" r="14" fill="none" stroke="currentColor" stroke-width="1.4" />
          <circle cx="16" cy="16" r="5" fill="currentColor" />
        </svg>
        <span>massocios<sup>·ai</sup></span>
      </a>
      <div class="v2-nav-pill">
        <a href="#producto">Producto</a>
        <a href="#flujo">Flujo</a>
        <a href="#precios">Precios</a>
        <a href="#faq">FAQ</a>
      </div>
      <div class="v2-nav-right">
        <a href={registroUrl} class="v2-cta-mini" target="_blank" rel="noopener noreferrer">
          <span class="dot-on"></span>
          Empezar
        </a>
      </div>
    </nav>

    <header class="v2-hero">
      <div class="v2-hero-tag">
        <span class="tag-id">[01]</span>
        <span class="tag-line"></span>
        <span class="tag-tx">v.2026.05 · whatsapp business api</span>
      </div>

      <h1 class="v2-h1">
        Atiende, agenda y<br />
        <span class="grad">cobra por vos.</span>
      </h1>

      <p class="v2-lead">
        El asistente conversacional que convierte cada chat de WhatsApp en un socio activo —
        con follow-ups automáticos, reservas en vivo y métricas de conversión <span class="ink">en tiempo real</span>.
      </p>

      <div class="v2-cta-row">
        <a href={registroUrl} class="v2-btn-primary" target="_blank" rel="noopener noreferrer">
          <span class="btn-pulse"></span>
          Iniciar prueba · 14 días
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href="#flujo" class="v2-btn-ghost">
          <span class="kbd-key">→</span>
          Ver el flujo completo
        </a>
      </div>

      <div class="v2-meta-strip">
        <span><b class="lime">●</b> WhatsApp API oficial</span>
        <span><b class="lime">●</b> Setup en &lt; 1h</span>
        <span><b class="lime">●</b> Soporte humano local</span>
        <span><b class="lime">●</b> UYU 1.800/mes</span>
      </div>

      <!-- inline product preview -->
      <div class="v2-preview" aria-label="Vista del producto">
        <div class="prev-frame">
          <div class="prev-bar">
            <span class="prev-dot red"></span>
            <span class="prev-dot yel"></span>
            <span class="prev-dot grn"></span>
            <span class="prev-url">app.massocios.ai / inbox</span>
            <span class="prev-pill">live</span>
          </div>
          <div class="prev-body">
            <aside class="prev-side">
              <div class="prev-head"><span class="lbl">INBOX</span><span class="num">12</span></div>
              <ul class="prev-list">
                <li class="active">
                  <span class="av">M</span>
                  <div>
                    <div class="row"><strong>Marcos G.</strong><span class="t">10:32</span></div>
                    <div class="msg">¿Cuándo me vence?</div>
                  </div>
                  <span class="ai-tag">ai</span>
                </li>
                <li>
                  <span class="av">L</span>
                  <div>
                    <div class="row"><strong>Lucía R.</strong><span class="t">10:28</span></div>
                    <div class="msg">Quiero el plan trimestral</div>
                  </div>
                  <span class="ai-tag warm">hot</span>
                </li>
                <li>
                  <span class="av">P</span>
                  <div>
                    <div class="row"><strong>Pedro C.</strong><span class="t">09:54</span></div>
                    <div class="msg">Reservar funcional 19hs</div>
                  </div>
                </li>
                <li>
                  <span class="av">S</span>
                  <div>
                    <div class="row"><strong>Sofi M.</strong><span class="t">08:12</span></div>
                    <div class="msg">Hola! Info de planes?</div>
                  </div>
                </li>
              </ul>
            </aside>
            <main class="prev-main">
              <div class="prev-conv-head">
                <div>
                  <div class="prev-name">Marcos González</div>
                  <div class="prev-sub">socio · plan mensual · vence en 8 días</div>
                </div>
                <div class="prev-actions">
                  <span class="chip">renovación</span>
                  <span class="chip alt">prioridad</span>
                </div>
              </div>
              <div class="prev-thread">
                <div class="bubble them">¿Cuándo me vence la membresía?</div>
                <div class="bubble me ai">
                  <span class="ai-prefix">ai</span>
                  Tu membresía vence el <b>15 de junio</b> (8 días). ¿Te paso link de renovación con 10% off por pago anticipado?
                  <div class="streaming"><span></span><span></span><span></span></div>
                </div>
                <div class="bubble them">Dale, mandalo</div>
                <div class="bubble me ai">
                  <span class="ai-prefix">ai</span>
                  Listo: <u>massocios.app/pay/m-3a9</u> · UYU 1.620 · 3 cuotas sin interés.
                </div>
              </div>
              <div class="prev-input">
                <span class="auto">auto · IA respondiendo</span>
                <span class="ai-status">
                  <span class="ai-dot"></span>
                  <span class="ai-dot"></span>
                  <span class="ai-dot"></span>
                </span>
              </div>
            </main>
          </div>
        </div>
      </div>
    </header>

    <section class="v2-marquee" aria-hidden="true">
      <div class="track">
        <span>+ 120 gimnasios</span><span>·</span>
        <span>3.2hs ahorradas / día</span><span>·</span>
        <span>98% consultas resueltas</span><span>·</span>
        <span>27% reactivación de socios</span><span>·</span>
        <span>&lt; 1 min de respuesta</span><span>·</span>
        <span>+ 120 gimnasios</span><span>·</span>
        <span>3.2hs ahorradas / día</span><span>·</span>
        <span>98% consultas resueltas</span><span>·</span>
      </div>
    </section>

    <!-- producto / capabilities -->
    <section class="v2-section" id="producto">
      <div class="v2-head">
        <span class="v2-eyebrow">// 02 · capacidades</span>
        <h2 class="v2-h2">Un agente entrenado<br/>en <span class="grad">tu gym</span>.</h2>
        <p class="v2-sub">Cuatro módulos. Una sola conversación. Trabaja sin pausa, escala al humano cuando lo necesita.</p>
      </div>

      <div class="v2-mod-grid">
        <article class="mod mod-1">
          <header>
            <span class="mod-id">// inbox</span>
            <h3>Bandeja unificada</h3>
          </header>
          <p>Cada mensaje, con la ficha completa del socio. Filtros por urgencia, estado de pago y conversión.</p>
          <div class="mod-vis">
            <div class="vis-row"><span class="dot grn"></span><span class="vis-name">Marcos G.</span><span class="vis-tag">renovación</span></div>
            <div class="vis-row"><span class="dot lime"></span><span class="vis-name">Lucía R.</span><span class="vis-tag warm">hot</span></div>
            <div class="vis-row"><span class="dot grey"></span><span class="vis-name">Pedro C.</span><span class="vis-tag">reserva</span></div>
          </div>
        </article>

        <article class="mod mod-2">
          <header>
            <span class="mod-id">// agent</span>
            <h3>Asistente IA conversacional</h3>
          </header>
          <p>Responde en el tono de tu marca. Detecta intención: consulta · venta · soporte · queja.</p>
          <div class="mod-vis vis-bubbles">
            <div class="bubble-mini them">¿Tienen pilates?</div>
            <div class="bubble-mini me">Sí, lun · mié · vie 9 y 19hs. ¿Te agendo prueba?</div>
            <div class="bubble-mini them">Dale</div>
            <div class="bubble-mini me confirm">✓ Agendado lun 19h</div>
          </div>
        </article>

        <article class="mod mod-3">
          <header>
            <span class="mod-id">// flow</span>
            <h3>Follow-ups automáticos</h3>
          </header>
          <p>Recordatorios de pago, vencimientos, reactivación a los 7 días sin check-in.</p>
          <div class="mod-vis vis-flow">
            <div class="flow-step"><b>D-3</b> recordatorio amable</div>
            <div class="flow-arrow">↓</div>
            <div class="flow-step"><b>D-1</b> link de pago</div>
            <div class="flow-arrow">↓</div>
            <div class="flow-step success"><b>D+1</b> confirmación</div>
          </div>
        </article>

        <article class="mod mod-4">
          <header>
            <span class="mod-id">// stats</span>
            <h3>Métricas de conversión</h3>
          </header>
          <p>Cuántos leads entraron, cuántos se hicieron socios, qué horas son las más calientes.</p>
          <div class="mod-vis vis-chart">
            <div class="bar" style="--h: 35%"></div>
            <div class="bar" style="--h: 55%"></div>
            <div class="bar" style="--h: 42%"></div>
            <div class="bar" style="--h: 78%"></div>
            <div class="bar hi" style="--h: 92%"></div>
            <div class="bar" style="--h: 70%"></div>
            <div class="bar" style="--h: 60%"></div>
          </div>
        </article>
      </div>
    </section>

    <!-- flujo / how it works -->
    <section class="v2-section" id="flujo">
      <div class="v2-head">
        <span class="v2-eyebrow">// 03 · flujo</span>
        <h2 class="v2-h2">De consulta a socio<br/>en <span class="grad">3 pasos</span>.</h2>
      </div>

      <ol class="v2-flow">
        <li>
          <div class="flow-num">01</div>
          <div class="flow-card">
            <h3>Conectás WhatsApp Business</h3>
            <p>QR único, 5 min. Sin perder tu historial. Sin cambiar tu número.</p>
            <code class="codeline">$ massocios connect --type=whatsapp-business</code>
          </div>
        </li>
        <li>
          <div class="flow-num">02</div>
          <div class="flow-card">
            <h3>Cargás el perfil del gym</h3>
            <p>Horarios, planes, profes, ubicación. El agente lee y responde como tu equipo.</p>
            <code class="codeline">→ context.json · 12 entries · synced</code>
          </div>
        </li>
        <li>
          <div class="flow-num">03</div>
          <div class="flow-card">
            <h3>El agente trabaja 24/7</h3>
            <p>Responde, agenda, cobra, hace follow-up. Te avisa solo cuando vale la pena escalarlo.</p>
            <code class="codeline lime">→ status: live · 12 conversations · 8 closed</code>
          </div>
        </li>
      </ol>
    </section>

    <!-- precios -->
    <section class="v2-section" id="precios">
      <div class="v2-head">
        <span class="v2-eyebrow">// 04 · planes</span>
        <h2 class="v2-h2">Pagás <span class="grad">menos</span> que un día<br/>de staff.</h2>
        <p class="v2-sub">Sin permanencia. Cancelás cuando quieras. Soporte humano en español.</p>
      </div>

      <div class="v2-price-grid">
        <article class="vprice">
          <div class="vprice-head">
            <h3>Starter</h3>
            <span class="vprice-tag">// para empezar</span>
          </div>
          <div class="vprice-amount">
            <span class="cur">UYU</span>
            <span class="amt">1.800</span>
            <span class="per">/ mes</span>
          </div>
          <ul>
            <li>Bandeja unificada de WhatsApp</li>
            <li>Notificaciones automáticas</li>
            <li>Hasta 200 socios</li>
            <li>Soporte por chat</li>
          </ul>
          <a href={registroUrl} class="vprice-cta" target="_blank" rel="noopener noreferrer">
            Empezar →
          </a>
        </article>

        <article class="vprice featured">
          <div class="vprice-glow"></div>
          <div class="vprice-head">
            <h3>Pro <span class="hot">popular</span></h3>
            <span class="vprice-tag">// agente IA incluido</span>
          </div>
          <div class="vprice-amount">
            <span class="cur">UYU</span>
            <span class="amt grad">3.200</span>
            <span class="per">/ mes</span>
          </div>
          <ul>
            <li>Todo lo de Starter</li>
            <li>Asistente IA 24/7 conversacional</li>
            <li>Follow-ups y reactivación automáticos</li>
            <li>Reservas y cobros por chat</li>
            <li>Sin límite de socios</li>
            <li>Reportes de conversión mensuales</li>
          </ul>
          <a href={registroUrl} class="vprice-cta primary" target="_blank" rel="noopener noreferrer">
            Probar 14 días gratis →
          </a>
        </article>
      </div>
    </section>

    <!-- faq -->
    <section class="v2-section" id="faq">
      <div class="v2-head">
        <span class="v2-eyebrow">// 05 · faq</span>
        <h2 class="v2-h2">Las dudas que ya<br/>nos hicieron <span class="grad">100 veces</span>.</h2>
      </div>
      <div class="v2-faq">
        <details>
          <summary><span class="qid">Q.01</span> ¿Necesito saber programar?<span class="caret">+</span></summary>
          <p>No. Setup visual, en español, en menos de una hora. Si no querés, lo configuramos por vos.</p>
        </details>
        <details>
          <summary><span class="qid">Q.02</span> ¿Funciona con mi número actual?<span class="caret">+</span></summary>
          <p>Sí, mientras sea WhatsApp Business. Si no lo tenés, te ayudamos a migrar sin perder tus chats.</p>
        </details>
        <details>
          <summary><span class="qid">Q.03</span> ¿Qué pasa si la IA no sabe responder?<span class="caret">+</span></summary>
          <p>Te avisa al instante y te pasa la conversación con todo el contexto. Nunca dejás a un socio sin respuesta.</p>
        </details>
        <details>
          <summary><span class="qid">Q.04</span> ¿Puedo probarlo antes de pagar?<span class="caret">+</span></summary>
          <p>14 días gratis, sin tarjeta. Si no te convence, te devolvemos el setup y conservás tus chats.</p>
        </details>
        <details>
          <summary><span class="qid">Q.05</span> ¿Mis datos están seguros?<span class="caret">+</span></summary>
          <p>API oficial de WhatsApp Business. Datos cifrados, alojados en AWS. Cumplimos con la ley uruguaya 18.331.</p>
        </details>
      </div>
    </section>

    <!-- final cta -->
    <section class="v2-final">
      <div class="final-bg" aria-hidden="true"></div>
      <div class="final-inner">
        <span class="v2-eyebrow center">// next step</span>
        <h2 class="final-h">
          Probalo gratis.<br/>
          <span class="grad">Cancelá cuando quieras.</span>
        </h2>
        <p>14 días sin tarjeta · setup asistido · soporte humano en Montevideo.</p>
        <a href={registroUrl} class="v2-btn-primary big" target="_blank" rel="noopener noreferrer">
          <span class="btn-pulse"></span>
          Iniciar prueba ahora
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </section>

    <footer class="v2-foot">
      <div class="foot-top">
        <a href="/" class="v2-logo small">
          <svg viewBox="0 0 32 32" aria-hidden="true"><circle cx="16" cy="16" r="14" fill="none" stroke="currentColor" stroke-width="1.4" /><circle cx="16" cy="16" r="5" fill="currentColor" /></svg>
          <span>massocios<sup>·ai</sup></span>
        </a>
        <div class="foot-cols">
          <div>
            <h4>producto</h4>
            <a href="#producto">Capacidades</a>
            <a href="#flujo">Flujo</a>
            <a href="#precios">Precios</a>
          </div>
          <div>
            <h4>empresa</h4>
            <a href="mailto:hola@massocios.com">Contacto</a>
            <a href="/">Sobre</a>
          </div>
          <div>
            <h4>legal</h4>
            <a href="/">Términos</a>
            <a href="/">Privacidad</a>
          </div>
        </div>
      </div>
      <div class="foot-bot">
        <span>© 2026 MasSocios · hecho en Montevideo</span>
        <span class="status"><span class="dot-on small"></span> all systems operational</span>
      </div>
    </footer>
  </div>
</Layout>

<style is:global>
  .v2-root {
    --bg: #0a100d;
    --bg-2: #0f1612;
    --panel: #131a16;
    --panel-2: #1a221d;
    --line: #1f2924;
    --line-2: #2a3530;
    --ink: #e8ede9;
    --ink-2: #b9c4be;
    --mute: #7a8580;
    --green: #25d366;
    --green-deep: #1faa53;
    --lime: #c7f284;
    --lime-soft: #2a3a1f;
    --red: #ff5d5d;

    background: var(--bg);
    color: var(--ink);
    font-family: 'Geist', 'Inter Tight', system-ui, sans-serif;
    line-height: 1.55;
    position: relative;
    overflow-x: hidden;
    min-height: 100vh;
  }

  .v2-root .sr-only {
    position: absolute; width: 1px; height: 1px;
    overflow: hidden; clip: rect(0 0 0 0);
  }

  .v2-root .grid-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--green) 6%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--green) 6%, transparent) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(circle at 50% 0%, black 0%, transparent 70%);
    pointer-events: none;
  }
  .v2-root .glow {
    position: fixed;
    width: 600px; height: 600px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(80px);
    opacity: 0.4;
  }
  .v2-root .glow-1 {
    background: radial-gradient(circle, var(--green) 0%, transparent 60%);
    top: -200px; left: -200px;
  }
  .v2-root .glow-2 {
    background: radial-gradient(circle, var(--lime) 0%, transparent 60%);
    top: 30%; right: -250px;
    opacity: 0.18;
  }

  /* nav */
  .v2-nav {
    position: sticky; top: 16px;
    z-index: 50;
    margin: 16px clamp(16px, 3vw, 32px) 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px 10px 18px;
    background: color-mix(in srgb, var(--panel) 70%, transparent);
    backdrop-filter: blur(16px) saturate(140%);
    border: 1px solid var(--line);
    border-radius: 999px;
  }
  .v2-logo {
    display: inline-flex; align-items: center; gap: 10px;
    text-decoration: none; color: var(--ink);
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 600;
    font-size: 17px;
    letter-spacing: -0.02em;
  }
  .v2-logo svg { width: 22px; height: 22px; color: var(--green); }
  .v2-logo sup { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--lime); margin-left: 2px; vertical-align: super; }
  .v2-nav-pill {
    display: flex; align-items: center; gap: 4px;
    padding: 4px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 999px;
  }
  .v2-nav-pill a {
    padding: 8px 14px;
    font-size: 13.5px;
    color: var(--ink-2);
    text-decoration: none;
    border-radius: 999px;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .v2-nav-pill a:hover { background: var(--panel-2); color: var(--ink); }
  .v2-cta-mini {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 16px;
    background: var(--green);
    color: var(--bg);
    text-decoration: none;
    border-radius: 999px;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.18s ease, transform 0.18s ease;
  }
  .v2-cta-mini:hover { background: var(--lime); }
  .dot-on {
    width: 8px; height: 8px; border-radius: 999px;
    background: var(--bg);
    box-shadow: 0 0 0 0 currentColor;
    animation: v2pulse 1.6s ease-out infinite;
  }
  .dot-on.small { width: 6px; height: 6px; background: var(--green); }
  @keyframes v2pulse {
    0% { box-shadow: 0 0 0 0 currentColor; }
    100% { box-shadow: 0 0 0 6px transparent; }
  }
  @media (max-width: 760px) {
    .v2-nav-pill { display: none; }
  }

  /* hero */
  .v2-hero {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(40px, 7vw, 88px) clamp(20px, 4vw, 48px) 60px;
  }
  .v2-hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--mute);
    margin-bottom: 32px;
  }
  .tag-id { color: var(--lime); }
  .tag-line {
    width: 60px; height: 1px;
    background: linear-gradient(90deg, var(--lime), transparent);
  }

  .v2-h1 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 600;
    font-size: clamp(48px, 9vw, 130px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    margin: 0;
    color: var(--ink);
  }
  .grad {
    background: linear-gradient(120deg, var(--green) 0%, var(--lime) 60%, var(--green) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% 100%;
    animation: v2grad 6s ease-in-out infinite;
  }
  @keyframes v2grad {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .v2-lead {
    font-size: clamp(17px, 1.5vw, 21px);
    color: var(--ink-2);
    max-width: 620px;
    margin: 30px 0 36px;
    line-height: 1.55;
  }
  .v2-lead .ink { color: var(--ink); border-bottom: 1px dashed var(--green); }

  .v2-cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 36px; }
  .v2-btn-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 22px;
    background: var(--green);
    color: var(--bg);
    text-decoration: none;
    border-radius: 12px;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.2s ease;
    box-shadow: 0 0 0 1px var(--green-deep), 0 12px 30px -8px color-mix(in srgb, var(--green) 60%, transparent);
    overflow: hidden;
  }
  .v2-btn-primary:hover {
    background: var(--lime);
    box-shadow: 0 0 0 1px var(--lime), 0 14px 36px -8px color-mix(in srgb, var(--lime) 70%, transparent);
  }
  .v2-btn-primary svg { width: 16px; height: 16px; }
  .v2-btn-primary.big { padding: 20px 30px; font-size: 17px; }
  .btn-pulse {
    width: 8px; height: 8px;
    border-radius: 999px;
    background: var(--bg);
    margin-right: 4px;
    animation: v2pulse 1.4s ease-out infinite;
  }
  .v2-btn-ghost {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 15px 20px;
    border: 1px solid var(--line-2);
    background: var(--panel);
    color: var(--ink);
    text-decoration: none;
    border-radius: 12px;
    font-weight: 500;
    font-size: 15px;
    transition: background 0.18s ease, border-color 0.18s ease;
    cursor: pointer;
  }
  .v2-btn-ghost:hover { background: var(--panel-2); border-color: var(--green); }
  .kbd-key {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px;
    border-radius: 5px;
    background: var(--bg);
    border: 1px solid var(--line-2);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--lime);
  }

  .v2-meta-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    color: var(--mute);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    margin-bottom: 56px;
  }
  .v2-meta-strip b.lime { color: var(--lime); margin-right: 6px; }

  /* preview frame */
  .v2-preview {
    position: relative;
    margin-top: 40px;
    perspective: 1500px;
  }
  .prev-frame {
    background: var(--panel);
    border: 1px solid var(--line-2);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 40px 80px -30px rgba(0,0,0,0.7), 0 0 0 1px var(--line);
    transform: rotateX(2deg);
    transform-style: preserve-3d;
  }
  .prev-bar {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 16px;
    background: var(--bg-2);
    border-bottom: 1px solid var(--line);
  }
  .prev-dot { width: 11px; height: 11px; border-radius: 999px; }
  .prev-dot.red { background: #ff5f57; }
  .prev-dot.yel { background: #febc2e; }
  .prev-dot.grn { background: #28c840; }
  .prev-url {
    margin-left: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--mute);
    flex: 1;
  }
  .prev-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--bg);
    background: var(--lime);
    padding: 3px 9px;
    border-radius: 999px;
    font-weight: 600;
    text-transform: uppercase;
  }
  .prev-body {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 460px;
  }
  @media (max-width: 760px) {
    .prev-body { grid-template-columns: 1fr; }
    .prev-side { display: none; }
  }
  .prev-side {
    border-right: 1px solid var(--line);
    background: var(--bg-2);
  }
  .prev-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 16px 18px;
    border-bottom: 1px solid var(--line);
  }
  .prev-head .lbl {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--mute);
    letter-spacing: 0.1em;
  }
  .prev-head .num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--lime);
    background: var(--lime-soft);
    padding: 2px 8px;
    border-radius: 999px;
  }
  .prev-list { list-style: none; margin: 0; padding: 8px; }
  .prev-list li {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.18s ease;
    align-items: center;
  }
  .prev-list li:hover { background: var(--panel); }
  .prev-list li.active { background: var(--panel); border-left: 2px solid var(--green); padding-left: 10px; }
  .prev-list .av {
    width: 28px; height: 28px;
    border-radius: 999px;
    background: var(--green);
    color: var(--bg);
    display: grid; place-items: center;
    font-size: 12px; font-weight: 700;
  }
  .prev-list .row { display: flex; justify-content: space-between; align-items: center; }
  .prev-list strong { font-size: 13px; color: var(--ink); }
  .prev-list .t { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; color: var(--mute); }
  .prev-list .msg { font-size: 12px; color: var(--mute); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ai-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--lime);
    background: var(--lime-soft);
    padding: 2px 7px;
    border-radius: 999px;
    text-transform: uppercase;
  }
  .ai-tag.warm { color: #ffb85c; background: #3a2a14; }

  .prev-main { padding: 16px 20px; display: flex; flex-direction: column; }
  .prev-conv-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    border-bottom: 1px solid var(--line);
    padding-bottom: 14px; margin-bottom: 16px;
  }
  .prev-name { font-weight: 600; font-size: 15px; }
  .prev-sub { font-family: 'JetBrains Mono', monospace; font-size: 11.5px; color: var(--mute); margin-top: 2px; }
  .prev-actions { display: flex; gap: 6px; }
  .chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    padding: 4px 9px;
    border-radius: 999px;
    background: var(--panel-2);
    color: var(--ink-2);
    border: 1px solid var(--line-2);
  }
  .chip.alt { color: var(--lime); border-color: var(--lime-soft); }

  .prev-thread { display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .bubble {
    max-width: 78%;
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 14px;
    line-height: 1.5;
    position: relative;
  }
  .bubble.them {
    background: var(--panel-2);
    color: var(--ink);
    border-bottom-left-radius: 4px;
    align-self: flex-start;
  }
  .bubble.me {
    background: var(--green);
    color: var(--bg);
    border-bottom-right-radius: 4px;
    align-self: flex-end;
  }
  .bubble.me.ai { background: linear-gradient(135deg, var(--green) 0%, var(--lime) 100%); }
  .bubble.me u { text-decoration-style: dotted; }
  .ai-prefix {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    text-transform: uppercase;
    background: var(--bg);
    color: var(--lime);
    padding: 2px 6px;
    border-radius: 4px;
    margin-right: 8px;
    font-weight: 700;
  }
  .streaming { display: inline-flex; gap: 3px; margin-left: 6px; vertical-align: middle; }
  .streaming span {
    width: 4px; height: 4px;
    border-radius: 999px;
    background: var(--bg);
    animation: stream 1s ease-in-out infinite;
  }
  .streaming span:nth-child(2) { animation-delay: 0.15s; }
  .streaming span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes stream {
    0%, 100% { opacity: 0.3; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(-2px); }
  }
  .prev-input {
    margin-top: 16px;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 10px;
    display: flex; justify-content: space-between; align-items: center;
    background: var(--bg-2);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--mute);
  }
  .auto::before { content: '› '; color: var(--lime); }
  .ai-status { display: inline-flex; gap: 4px; }
  .ai-dot {
    width: 5px; height: 5px;
    border-radius: 999px;
    background: var(--lime);
    animation: stream 1s ease-in-out infinite;
  }
  .ai-dot:nth-child(2) { animation-delay: 0.15s; }
  .ai-dot:nth-child(3) { animation-delay: 0.3s; }

  /* marquee */
  .v2-marquee {
    position: relative; z-index: 1;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
    padding: 18px 0;
    background: var(--bg-2);
  }
  .v2-marquee .track {
    display: flex; gap: 36px;
    white-space: nowrap;
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: clamp(20px, 2.4vw, 30px);
    font-weight: 500;
    color: var(--mute);
    animation: v2marquee 28s linear infinite;
  }
  .v2-marquee .track span:nth-child(odd) { color: var(--ink); }
  .v2-marquee .track span:nth-child(2n) { color: var(--green); font-family: 'JetBrains Mono', monospace; font-size: 0.8em; }
  @keyframes v2marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* sections */
  .v2-section {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(80px, 11vw, 140px) clamp(20px, 4vw, 48px);
  }
  .v2-head { max-width: 760px; margin-bottom: 60px; }
  .v2-eyebrow {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--lime);
    margin-bottom: 18px;
    letter-spacing: 0.04em;
  }
  .v2-eyebrow.center { display: block; text-align: center; }
  .v2-h2 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 600;
    font-size: clamp(40px, 6.5vw, 88px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    margin: 0;
  }
  .v2-sub { margin-top: 22px; color: var(--ink-2); font-size: 18px; max-width: 560px; }

  /* modules */
  .v2-mod-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  @media (max-width: 760px) { .v2-mod-grid { grid-template-columns: 1fr; } }
  .mod {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 28px;
    transition: border-color 0.2s ease, background 0.2s ease;
    position: relative;
    overflow: hidden;
  }
  .mod:hover { border-color: var(--green); background: var(--panel-2); }
  .mod-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--lime);
    text-transform: lowercase;
    margin-bottom: 8px;
    display: inline-block;
  }
  .mod h3 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .mod p { color: var(--ink-2); font-size: 15px; margin: 0 0 22px; }
  .mod-vis {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 18px;
    margin-top: 8px;
  }
  .vis-row {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 0;
    border-bottom: 1px dashed var(--line);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
  }
  .vis-row:last-child { border-bottom: none; }
  .vis-row .dot { width: 8px; height: 8px; border-radius: 999px; }
  .vis-row .dot.grn { background: var(--green); }
  .vis-row .dot.lime { background: var(--lime); }
  .vis-row .dot.grey { background: var(--mute); }
  .vis-name { color: var(--ink); flex: 1; }
  .vis-tag {
    font-size: 10px;
    color: var(--ink-2);
    background: var(--panel-2);
    padding: 2px 8px;
    border-radius: 999px;
    text-transform: uppercase;
  }
  .vis-tag.warm { color: var(--lime); background: var(--lime-soft); }

  .vis-bubbles { display: flex; flex-direction: column; gap: 6px; }
  .bubble-mini {
    padding: 8px 12px;
    border-radius: 12px;
    font-size: 13px;
    max-width: 80%;
  }
  .bubble-mini.them { background: var(--panel-2); color: var(--ink); align-self: flex-start; border-bottom-left-radius: 4px; }
  .bubble-mini.me { background: var(--green); color: var(--bg); align-self: flex-end; border-bottom-right-radius: 4px; font-weight: 500; }
  .bubble-mini.confirm { background: var(--lime); color: var(--bg); align-self: flex-end; font-weight: 600; }

  .vis-flow { display: flex; flex-direction: column; gap: 4px; align-items: stretch; }
  .flow-step {
    background: var(--panel-2);
    padding: 10px 14px;
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: var(--ink-2);
  }
  .flow-step b { color: var(--lime); margin-right: 10px; }
  .flow-step.success { background: var(--lime-soft); color: var(--lime); border: 1px solid var(--lime); }
  .flow-arrow { text-align: center; color: var(--mute); font-family: 'JetBrains Mono', monospace; }

  .vis-chart {
    display: flex; align-items: flex-end; gap: 8px;
    height: 110px;
  }
  .vis-chart .bar {
    flex: 1;
    background: var(--panel-2);
    border-radius: 4px 4px 0 0;
    height: var(--h);
    transition: background 0.3s ease;
  }
  .vis-chart .bar.hi {
    background: linear-gradient(180deg, var(--lime), var(--green));
  }

  /* flow */
  .v2-flow { list-style: none; padding: 0; margin: 0; display: grid; gap: 16px; }
  .v2-flow li {
    display: grid;
    grid-template-columns: 120px 1fr;
    align-items: stretch;
    gap: 16px;
  }
  @media (max-width: 720px) { .v2-flow li { grid-template-columns: 1fr; } }
  .flow-num {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: clamp(60px, 10vw, 120px);
    font-weight: 600;
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1px var(--line-2);
  }
  .flow-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 28px;
    transition: border-color 0.2s ease;
  }
  .flow-card:hover { border-color: var(--green); }
  .flow-card h3 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 600;
    font-size: 24px;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  .flow-card p { color: var(--ink-2); margin: 0 0 16px; font-size: 15px; }
  .codeline {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: var(--ink-2);
    background: var(--bg);
    padding: 8px 14px;
    border-radius: 8px;
    border: 1px solid var(--line);
  }
  .codeline.lime { color: var(--lime); }

  /* pricing */
  .v2-price-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    max-width: 920px;
    margin: 0 auto;
  }
  @media (max-width: 720px) { .v2-price-grid { grid-template-columns: 1fr; } }
  .vprice {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.2s ease;
  }
  .vprice:hover { transform: translateY(-4px); border-color: var(--green); }
  .vprice.featured {
    background: var(--bg-2);
    border-color: var(--green);
    box-shadow: 0 0 0 1px var(--green-deep), 0 30px 80px -30px color-mix(in srgb, var(--green) 50%, transparent);
  }
  .vprice-glow {
    position: absolute;
    width: 380px; height: 380px;
    background: radial-gradient(circle, var(--lime) 0%, transparent 65%);
    top: -150px; right: -150px;
    opacity: 0.15;
    pointer-events: none;
  }
  .vprice-head h3 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 600;
    font-size: 26px;
    margin: 0 0 4px;
    letter-spacing: -0.02em;
    display: flex; align-items: center; gap: 10px;
  }
  .vprice-head h3 .hot {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--bg);
    background: var(--lime);
    padding: 3px 8px;
    border-radius: 999px;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .vprice-tag { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--mute); }
  .vprice-amount {
    display: flex;
    align-items: baseline;
    gap: 6px;
    font-family: 'Bricolage Grotesque', sans-serif;
  }
  .vprice-amount .cur { font-size: 14px; color: var(--mute); font-family: 'JetBrains Mono', monospace; }
  .vprice-amount .amt { font-size: 56px; font-weight: 600; line-height: 1; letter-spacing: -0.04em; }
  .vprice-amount .per { font-size: 14px; color: var(--mute); font-family: 'JetBrains Mono', monospace; }
  .vprice ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .vprice li {
    font-size: 14.5px;
    color: var(--ink-2);
    padding-left: 24px;
    position: relative;
  }
  .vprice li::before {
    content: '';
    position: absolute;
    left: 0; top: 8px;
    width: 12px; height: 7px;
    border-left: 2px solid var(--green);
    border-bottom: 2px solid var(--green);
    transform: rotate(-45deg);
  }
  .vprice-cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 22px;
    border-radius: 12px;
    background: var(--panel-2);
    color: var(--ink);
    border: 1px solid var(--line-2);
    text-decoration: none;
    font-weight: 500;
    transition: background 0.18s ease, border-color 0.18s ease;
    cursor: pointer;
  }
  .vprice-cta:hover { background: var(--bg); border-color: var(--green); }
  .vprice-cta.primary {
    background: var(--green);
    color: var(--bg);
    border-color: var(--green);
    font-weight: 600;
  }
  .vprice-cta.primary:hover { background: var(--lime); border-color: var(--lime); }

  /* faq */
  .v2-faq {
    max-width: 760px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
  }
  .v2-faq details {
    border-bottom: 1px solid var(--line);
  }
  .v2-faq details:last-child { border-bottom: none; }
  .v2-faq summary {
    padding: 22px 26px;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 500;
    font-size: 17px;
    color: var(--ink);
    transition: background 0.18s ease;
  }
  .v2-faq summary:hover { background: var(--panel-2); }
  .v2-faq summary::-webkit-details-marker { display: none; }
  .v2-faq .qid {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--lime);
    margin-right: 14px;
    flex-shrink: 0;
  }
  .v2-faq .caret {
    font-family: 'JetBrains Mono', monospace;
    color: var(--mute);
    font-size: 18px;
    margin-left: auto;
    transition: transform 0.2s ease;
  }
  .v2-faq details[open] .caret { transform: rotate(45deg); color: var(--green); }
  .v2-faq p {
    padding: 0 26px 22px;
    color: var(--ink-2);
    font-size: 15px;
    margin: 0;
  }

  /* final */
  .v2-final {
    position: relative;
    z-index: 1;
    margin: 0 clamp(20px, 4vw, 48px) 60px;
    padding: clamp(70px, 12vw, 160px) clamp(28px, 6vw, 80px);
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 32px;
    text-align: center;
    overflow: hidden;
  }
  .final-bg {
    position: absolute;
    inset: 0;
    background:
