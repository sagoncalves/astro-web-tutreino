---
import Layout from '../layouts/Layout.astro';
import { createPageMeta, PAGE_META, SITE_CONFIG } from '../utils/meta';

const metaData = createPageMeta('/v3', PAGE_META.home);
const registroUrl = SITE_CONFIG.appRegistrationUrl;
---

<Layout {...metaData} showHeader={false}>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@500;700;800&family=Manrope:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap"
  />

  <div class="v3-root">
    <h2 class="sr-only">MasSocios — el bot de WhatsApp que llena tu gym</h2>

    <!-- top banner -->
    <div class="v3-banner" aria-hidden="false">
      <div class="banner-track">
        <span>★ HECHO EN URUGUAY</span>
        <span>—</span>
        <span>14 DÍAS GRATIS</span>
        <span>—</span>
        <span>★ SIN TARJETA</span>
        <span>—</span>
        <span>120+ GIMNASIOS</span>
        <span>—</span>
        <span>★ SETUP EN 1 TARDE</span>
        <span>—</span>
        <span>★ HECHO EN URUGUAY</span>
        <span>—</span>
        <span>14 DÍAS GRATIS</span>
        <span>—</span>
        <span>★ SIN TARJETA</span>
        <span>—</span>
        <span>120+ GIMNASIOS</span>
        <span>—</span>
        <span>★ SETUP EN 1 TARDE</span>
      </div>
    </div>

    <nav class="v3-nav" aria-label="Principal">
      <a href="/" class="v3-logo">
        <span class="logo-mark">M</span>
        <span class="logo-text">MasSocios</span>
      </a>
      <div class="v3-nav-links">
        <a href="#problema">Problema</a>
        <a href="#solucion">Solución</a>
        <a href="#precios">Precios</a>
        <a class="v3-nav-cta" href={registroUrl} target="_blank" rel="noopener noreferrer">
          Probar gratis
          <span class="arrow">↗</span>
        </a>
      </div>
    </nav>

    <header class="v3-hero">
      <div class="hero-grid">
        <div class="hero-left">
          <div class="hero-tag">
            <span class="ball"></span>
            BOT DE WHATSAPP · GIMNASIOS
          </div>
          <h1 class="v3-h1">
            Tu gym,<br/>
            <span class="hl-yellow">lleno.</span><br/>
            Tu staff,<br/>
            <span class="hl-magenta">tranquilo.</span>
          </h1>
          <p class="v3-lead">
            <strong>MasSocios</strong> contesta cada consulta de WhatsApp, agenda clases de prueba y
            hace los seguimientos que tu equipo nunca tiene tiempo de hacer.
            <span class="and">Y convierte. Mucho.</span>
          </p>
          <div class="v3-cta-row">
            <a href={registroUrl} class="v3-btn-primary" target="_blank" rel="noopener noreferrer">
              EMPEZAR GRATIS
              <span class="big-arrow">→</span>
            </a>
            <a href="#solucion" class="v3-btn-link">
              ¿Cómo funciona?
            </a>
          </div>
          <div class="hero-strip">
            <div class="strip-i">
              <span class="strip-n">14</span>
              <span class="strip-l">días<br/>gratis</span>
            </div>
            <div class="divider"></div>
            <div class="strip-i">
              <span class="strip-n">0$</span>
              <span class="strip-l">sin<br/>tarjeta</span>
            </div>
            <div class="divider"></div>
            <div class="strip-i">
              <span class="strip-n">1h</span>
              <span class="strip-l">de<br/>setup</span>
            </div>
          </div>
        </div>

        <div class="hero-right">
          <!-- phone mockup -->
          <div class="phone">
            <div class="phone-notch"></div>
            <div class="phone-screen">
              <div class="phone-bar">
                <span class="phone-time">10:32</span>
                <span class="phone-icons">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M2 17h20v2H2v-2zm1.5-7.5L4 12l4.5-4.5L7 6 1.5 11.5l1.5 1.5zm9 4l1.5-1.5L9 7.5 7.5 9l3 3zm9-9.5L20 5l-1-1L20 3l1.5-1.5z"/></svg>
                </span>
              </div>
              <div class="phone-conv-head">
                <span class="phone-back">‹</span>
                <span class="phone-av">G</span>
                <div>
                  <div class="phone-name">Gym Pacífico</div>
                  <div class="phone-status"><span class="online"></span>en línea</div>
                </div>
              </div>
              <div class="phone-msgs">
                <div class="m-meta">HOY</div>
                <div class="msg out">
                  Hola! Vi un poster en la calle. Cuánto sale el funcional?
                  <span class="msg-time">10:31</span>
                </div>
                <div class="msg in">
                  Hola! Bienvenida 👋
                  <span class="msg-time">10:31</span>
                </div>
                <div class="msg in">
                  El plan funcional sale <b>UYU 1.800/mes</b>. Si pagás trimestral te queda <b>1.620</b> 💪
                  <br/><br/>
                  ¿Te gustaría una <u>clase de prueba GRATIS</u> esta semana?
                  <span class="msg-time">10:31</span>
                </div>
                <div class="msg out">
                  Sí, mañana 19hs?
                  <span class="msg-time">10:32</span>
                </div>
                <div class="msg in confirm">
                  ✓ Reservado · Mañana 19hs
                  Te paso ubicación y aviso 1h antes 🙌
                  <span class="msg-time">10:32</span>
                </div>
                <div class="typing">
                  <span></span><span></span><span></span>
                </div>
              </div>
            </div>
            <!-- floating sticker -->
            <div class="sticker sticker-1">
              <span>+1<br/>CLIENTE</span>
            </div>
            <div class="sticker sticker-2">
              ⚡<br/>0 humanos
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- big stats block -->
    <section class="v3-stats">
      <div class="stat-card stat-yellow">
        <div class="stat-num">68%</div>
        <div class="stat-lbl">Leads que terminan agendando una visita</div>
      </div>
      <div class="stat-card stat-teal">
        <div class="stat-num">3,2hs</div>
        <div class="stat-lbl">Que tu staff deja de perder cada día</div>
      </div>
      <div class="stat-card stat-magenta">
        <div class="stat-num">×4</div>
        <div class="stat-lbl">Más conversiones que respondiendo a mano</div>
      </div>
      <div class="stat-card stat-cream">
        <div class="stat-num">24/7</div>
        <div class="stat-lbl">Hasta los domingos a las 23:50</div>
      </div>
    </section>

    <!-- problem block -->
    <section class="v3-block v3-problem" id="problema">
      <div class="block-head">
        <span class="eyebrow">EL PROBLEMA</span>
        <h2 class="v3-h2">
          Cada mensaje sin responder<br/>
          es <span class="strike">plata</span> <span class="hl-magenta italic">plata</span><br/>
          que se va a otro gym.
        </h2>
      </div>

      <div class="problem-grid">
        <article class="prob-card">
          <div class="prob-num">01</div>
          <h3>Las 11pm también cuenta</h3>
          <p>Un cliente consulta precios un domingo a la noche. Si nadie le contesta hasta el lunes 10am, ya buscó otro gym.</p>
        </article>
        <article class="prob-card">
          <div class="prob-num">02</div>
          <h3>Las mismas 5 preguntas</h3>
          <p>Precios, horarios, dirección, planes, profes. Tu equipo repite lo mismo 30 veces por día. Aburre. Y se equivoca.</p>
        </article>
        <article class="prob-card">
          <div class="prob-num">03</div>
          <h3>Clientes que se van calladitos</h3>
          <p>No avisan. Solo dejan de aparecer. Y nadie tiene tiempo de llamarlos para preguntar qué pasó.</p>
        </article>
        <article class="prob-card">
          <div class="prob-num">04</div>
          <h3>Clases con lugares vacíos</h3>
          <p>Reservas que nadie confirmó. Lugares que se quedaron libres. Ingresos que no entraron.</p>
        </article>
      </div>
    </section>

    <!-- solution block (yellow) -->
    <section class="v3-block v3-solution" id="solucion">
      <div class="solution-inner">
        <div class="block-head">
          <span class="eyebrow inverse">LA SOLUCIÓN</span>
          <h2 class="v3-h2 inverse">
            Un asistente que<br/>
            <em>nunca duerme.</em><br/>
            Y que <span class="hl-magenta-block">vende.</span>
          </h2>
        </div>

        <div class="sol-grid">
          <article class="sol-card">
            <div class="sol-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3>Conversaciones que <em>convierten</em></h3>
            <p>Identifica leads calientes. Agenda clases de prueba. Empuja a la inscripción con el tono de tu marca.</p>
          </article>

          <article class="sol-card">
            <div class="sol-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3>Follow-ups <em>automáticos</em></h3>
            <p>Recordatorios de pago, vencimientos, cumpleaños y reactivación de clientes que dejaron de venir.</p>
          </article>

          <article class="sol-card">
            <div class="sol-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" />
                <path d="M16 2v4M8 2v4M3 10h18" stroke-linecap="round" />
              </svg>
            </div>
            <h3>Reservas <em>por chat</em></h3>
            <p>El cliente reserva su clase desde WhatsApp. Sin apps. Sin login. Sin fricción.</p>
          </article>

          <article class="sol-card">
            <div class="sol-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                <path d="M3 3v18h18" stroke-linecap="round" />
                <path d="M7 14l4-4 4 4 5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3>Métricas <em>de verdad</em></h3>
            <p>Cuántos leads convertiste. Qué consultas se repiten. Cuánto tiempo te ahorraste. Sin Excel.</p>
          </article>

          <article class="sol-card">
            <div class="sol-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke-linecap="round" />
                <circle cx="9" cy="7" r="4" />
                <path d="M22 11l-3 3-2-2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3>Bandeja <em>unificada</em></h3>
            <p>Todos los chats con la ficha del cliente al lado. Tu equipo nunca pregunta dos veces lo mismo.</p>
          </article>

          <article class="sol-card">
            <div class="sol-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                <path d="M12 2L2 7l10 5 10-5-10-5z" stroke-linejoin="round" stroke-linecap="round" />
                <path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke-linejoin="round" stroke-linecap="round" />
              </svg>
            </div>
            <h3>Escalado <em>al humano</em></h3>
            <p>Cuando el bot no la sabe, te avisa al toque y te pasa la conversación con todo el contexto.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- inbox preview - what YOU see as the operator -->
    <section class="v3-block v3-inbox">
      <div class="block-head">
        <span class="eyebrow">LO QUE VOS VES</span>
        <h2 class="v3-h2">
          Una bandeja.<br/>
          Todos tus clientes.<br/>
          <span class="hl-yellow">Cero caos.</span>
        </h2>
        <p class="v3-sub">Mientras el bot conversa, vos mirás todo desde un solo lugar — con la ficha del cliente, el estado de pago y la prioridad de cada chat.</p>
      </div>

      <div class="inbox-frame">
        <div class="inbox-bar">
          <span class="inbox-dot red"></span>
          <span class="inbox-dot yel"></span>
          <span class="inbox-dot grn"></span>
          <span class="inbox-url">app.massocios.com / inbox</span>
          <span class="inbox-pill">live</span>
        </div>
        <div class="wa-body">
          <aside class="wa-side">
            <div class="wa-side-head">
              <div class="wa-side-me">
                <span class="wa-side-av">G</span>
                <div>
                  <div class="wa-side-name">Gym Pacífico</div>
                  <div class="wa-side-sub"><span class="wa-online"></span>conectado vía MasSocios</div>
                </div>
              </div>
              <span class="wa-pill"><span class="wa-pill-dot"></span>IA activa</span>
            </div>
            <div class="wa-search">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="7" />
                <path d="m20 20-3.5-3.5" stroke-linecap="round" />
              </svg>
              <span>Buscar un chat o cliente</span>
            </div>
            <div class="wa-tabs">
              <span class="wa-tab active">Todos</span>
              <span class="wa-tab">No leídos <b>3</b></span>
              <span class="wa-tab">IA</span>
              <span class="wa-tab hot">Hot</span>
            </div>
            <ul class="wa-list">
              <li class="active">
                <span class="wa-av av-m">M</span>
                <div class="wa-row-body">
                  <div class="wa-row-top">
                    <strong>Marcos González</strong>
                    <span class="wa-row-time">10:32</span>
                  </div>
                  <div class="wa-row-bot">
                    <span class="wa-row-msg">
                      <span class="wa-checks dbl read" aria-hidden="true">✓✓</span>
                      Listo: massocios.app/pay/m-3a9
                    </span>
                    <span class="wa-tag ai">IA</span>
                  </div>
                </div>
              </li>
              <li>
                <span class="wa-av av-l">L</span>
                <div class="wa-row-body">
                  <div class="wa-row-top">
                    <strong>Lucía Rodríguez</strong>
                    <span class="wa-row-time hot">10:28</span>
                  </div>
                  <div class="wa-row-bot">
                    <span class="wa-row-msg">Quiero el plan trimestral 💪</span>
                    <span class="wa-badge">2</span>
                  </div>
                </div>
              </li>
              <li>
                <span class="wa-av av-p">P</span>
                <div class="wa-row-body">
                  <div class="wa-row-top">
                    <strong>Pedro Cabrera</strong>
                    <span class="wa-row-time">09:54</span>
                  </div>
                  <div class="wa-row-bot">
                    <span class="wa-row-msg">
                      <span class="wa-checks dbl" aria-hidden="true">✓✓</span>
                      Reservar funcional 19hs
                    </span>
                  </div>
                </div>
              </li>
              <li>
                <span class="wa-av av-s">S</span>
                <div class="wa-row-body">
                  <div class="wa-row-top">
                    <strong>Sofía Morales</strong>
                    <span class="wa-row-time">08:12</span>
                  </div>
                  <div class="wa-row-bot">
                    <span class="wa-row-msg">Hola! Info de planes?</span>
                    <span class="wa-tag warm">hot</span>
                  </div>
                </div>
              </li>
              <li>
                <span class="wa-av av-d">D</span>
                <div class="wa-row-body">
                  <div class="wa-row-top">
                    <strong>Diego Pereyra</strong>
                    <span class="wa-row-time">ayer</span>
                  </div>
                  <div class="wa-row-bot">
                    <span class="wa-row-msg">
                      <span class="wa-checks dbl read" aria-hidden="true">✓✓</span>
                      Gracias!
                    </span>
                  </div>
                </div>
              </li>
            </ul>
          </aside>

          <main class="wa-main">
            <header class="wa-conv-head">
              <div class="wa-conv-id">
                <span class="wa-av av-m big">M</span>
                <div>
                  <div class="wa-conv-name">Marcos González</div>
                  <div class="wa-conv-sub">en línea · plan mensual · vence en 8 días</div>
                </div>
              </div>
              <div class="wa-conv-meta">
                <span class="wa-tag ai">respondiendo IA</span>
                <span class="wa-icon-btn" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5" stroke-linecap="round"/></svg>
                </span>
                <span class="wa-icon-btn" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></svg>
                </span>
              </div>
            </header>

            <div class="wa-thread">
              <div class="wa-day"><span>HOY</span></div>

              <div class="wa-msg in">
                <span class="wa-msg-text">¿Cuándo me vence la membresía?</span>
                <span class="wa-msg-time">10:31</span>
              </div>

              <div class="wa-msg out ai">
                <span class="wa-msg-prefix">IA · MasSocios</span>
                <span class="wa-msg-text">
                  Hola Marcos! Tu membresía vence el <b>15 de junio</b> (en 8 días).<br/>
                  ¿Te paso link de renovación con <b>10% off</b> por pago anticipado?
                </span>
                <span class="wa-msg-time">10:31 <span class="wa-checks read">✓✓</span></span>
              </div>

              <div class="wa-msg in">
                <span class="wa-msg-text">Dale, mandalo 🙌</span>
                <span class="wa-msg-time">10:32</span>
              </div>

              <div class="wa-msg out ai">
                <span class="wa-msg-prefix">IA · MasSocios</span>
                <span class="wa-msg-text">
                  Listo: <u>massocios.app/pay/m-3a9</u><br/>
                  · UYU <b>1.620</b> (10% off aplicado)<br/>
                  · 3 cuotas sin interés
                </span>
                <span class="wa-msg-time">10:32 <span class="wa-checks read">✓✓</span></span>
              </div>

              <div class="wa-typing"><span></span><span></span><span></span></div>
            </div>

            <footer class="wa-input">
              <span class="wa-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9 10h.01M15 10h.01M9 15c1 1 2 1.5 3 1.5s2-.5 3-1.5" stroke-linecap="round"/></svg>
              </span>
              <span class="wa-input-box">
                <span class="wa-input-auto">→ IA escribiendo respuesta automática</span>
                <span class="wa-typing inline"><span></span><span></span><span></span></span>
              </span>
              <span class="wa-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v14M5 9l7-7 7 7M5 21h14" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </footer>
          </main>
        </div>
      </div>
    </section>

    <!-- 3 steps -->
    <section class="v3-block v3-steps">
      <div class="block-head center">
        <span class="eyebrow">CÓMO EMPEZÁS</span>
        <h2 class="v3-h2">
          En <span class="hl-yellow">1 tarde,</span><br/>
          listo <em>para siempre.</em>
        </h2>
      </div>

      <div class="steps-grid">
        <article class="step-card">
          <div class="step-tag">
            <span class="step-num">1</span>
            <span class="step-time">5 MIN</span>
          </div>
          <h3>Conectás WhatsApp</h3>
          <p>Escaneás un QR. Listo. Sin cambiar de número, sin perder tus chats.</p>
        </article>
        <div class="step-arrow">→</div>
        <article class="step-card">
          <div class="step-tag">
            <span class="step-num">2</span>
            <span class="step-time">30 MIN</span>
          </div>
          <h3>Cargás info</h3>
          <p>Horarios, planes, profes, ubicación. El bot aprende cómo habla tu gym.</p>
        </article>
        <div class="step-arrow">→</div>
        <article class="step-card hot">
          <div class="step-tag">
            <span class="step-num">3</span>
            <span class="step-time">∞</span>
          </div>
          <h3>Empieza a convertir</h3>
          <p>Atiende, agenda, hace seguimiento. Te avisa solo cuando vale la pena.</p>
        </article>
      </div>
    </section>

    <!-- testimonial -->
    <section class="v3-block v3-testi">
      <div class="testi-card">
        <div class="testi-quote">"</div>
        <p class="testi-text">
          Antes contestaba mensajes hasta las 11 de la noche, siempre lo mismo.
          Hoy el bot me consigue <em>3 o 4 clases de prueba por día</em> sin que
          yo levante el celular. <strong>Cerré 12 clientes nuevos el mes pasado.</strong>
        </p>
        <div class="testi-author">
          <div class="testi-av">PV</div>
          <div>
            <div class="testi-name">Paula Villalba</div>
            <div class="testi-role">Dueña · Pacífico Gym, Pocitos</div>
          </div>
          <div class="testi-stars">★★★★★</div>
        </div>
      </div>
    </section>

    <!-- pricing block -->
    <section class="v3-block v3-pricing" id="precios">
      <div class="block-head center">
        <span class="eyebrow">PRECIOS</span>
        <h2 class="v3-h2">
          Pagás <span class="hl-yellow">menos</span><br/>
          que <em>un día de staff.</em>
        </h2>
        <p class="v3-sub">Sin permanencia. Cancelás cuando quieras. Soporte humano en 🇺🇾.</p>
